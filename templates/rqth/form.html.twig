{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
<style>
.rqth-form .form-control, .rqth-form .form-select {
    background-color: #eafaf1;
    border-color: #a9dfbf;
    color: #1e8449;
    font-size: .9rem;
}
.rqth-form .form-control:focus, .rqth-form .form-select:focus {
    background-color: #d5f5e3;
    border-color: #27ae60;
    box-shadow: 0 0 0 .2rem rgba(39,174,96,.2);
}
.rqth-form .card-header { font-weight: 600; font-size: .9rem; }
.sticky-save {
    position: sticky;
    bottom: 0;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(4px);
    padding: .75rem 1rem;
    border-top: 1px solid #dee2e6;
    z-index: 100;
    margin-top: 1rem;
}
input[type="file"]::file-selector-button {
    background-color: #198754;
    color: #fff;
    border: none;
    padding: .3rem .75rem;
    border-radius: .375rem;
    cursor: pointer;
    margin-right: .5rem;
}
input[type="file"]::file-selector-button:hover { background-color: #157347; }
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-badge"></i> {{ title }}</h2>
    <a href="{{ rqth is defined ? path('app_rqth_show', {id: rqth.id}) : path('app_rqth_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

{{ form_start(form, {attr: {enctype: 'multipart/form-data', class: 'rqth-form'}}) }}

<div class="card mb-3">
    <div class="card-header bg-success text-white"><i class="bi bi-person me-1"></i> Agent</div>
    <div class="card-body row g-2">
        <div class="col-auto">{{ form_row(form.genre, {attr: {class: 'form-select form-select-sm genre-autofill', style: 'width:120px'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.agentRqth, {attr: {class: 'form-control form-control-sm', style: 'text-transform:uppercase'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.prenomRqth, {attr: {class: 'form-control form-control-sm prenom-genre-trigger'}}) }}</div>
        <div class="col-md-4">{{ form_row(form.poleServiceRqth, {attr: {class: 'form-control form-control-sm'}}) }}</div>
        <div class="col-md-4">{{ form_row(form.emploiRqth, {attr: {class: 'form-control form-control-sm'}}) }}</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header bg-primary text-white"><i class="bi bi-award me-1"></i> RQTH</div>
    <div class="card-body row g-2">
        <div class="col-md-3">{{ form_row(form.etatRqth, {attr: {class: 'form-select form-select-sm'}}) }}</div>
        <div class="col-auto">{{ form_row(form.dateAttributionRqth, {attr: {class: 'form-control form-control-sm date-picker', style: 'width:150px'}}) }}</div>
        <div class="col-auto">{{ form_row(form.dateFinAttributionRqth, {attr: {class: 'form-control form-control-sm date-picker', style: 'width:150px'}}) }}</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header bg-secondary text-white"><i class="bi bi-paperclip me-1"></i> Documents</div>
    <div class="card-body">
        {% if rqth is defined and rqth.documents is not empty %}
        <ul class="list-group list-group-flush mb-3">
            {% for doc in rqth.documents %}
            <li class="list-group-item px-0 py-1 d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-pdf text-danger"></i>
                <a href="{{ app.request.basePath }}/uploads/rqth/{{ doc.filename }}" target="_blank" class="text-decoration-none small">{{ doc.nomOriginal }}</a>
            </li>
            {% endfor %}
        </ul>
        {% endif %}
        <input type="file" name="documentFiles[]" multiple accept=".pdf,.doc,.docx,.jpg,.png" class="form-control form-control-sm">
        <div class="form-text">Vous pouvez sélectionner plusieurs fichiers à la fois.</div>
    </div>
</div>

<div class="sticky-save">
    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ rqth is defined ? path('app_rqth_show', {id: rqth.id}) : path('app_rqth_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>

{{ form_end(form) }}
{% endblock %}
