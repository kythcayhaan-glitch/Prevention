{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-badge"></i> {{ title }}</h2>
    <a href="{{ path('app_rqth_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
<div class="card">
    <div class="card-body">
        {{ form_start(form) }}
        <div class="row g-3">
            <div class="col-md-4">{{ form_row(form.agentRqth, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.poleServiceRqth, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.emploiRqth, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.etatRqth, {attr: {class: 'form-select'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.dateAttributionRqth, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.dateFinAttributionRqth, {attr: {class: 'form-control'}}) }}</div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
            <a href="{{ path('app_rqth_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
