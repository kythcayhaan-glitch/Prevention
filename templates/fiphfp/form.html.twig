{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-cash-coin"></i> {{ title }}</h2>
    <a href="{{ path('app_fiphfp_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
<div class="card">
    <div class="card-body">
        {{ form_start(form) }}
        <div class="row g-3">
            <div class="col-md-4">{{ form_row(form.agentFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.poleFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.demandeFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.dateDemandeFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.objetFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-4">{{ form_row(form.etatDemandeFiphfp, {attr: {class: 'form-select'}}) }}</div>
            <div class="col-12">{{ form_row(form.detailDemandeFiphfp, {attr: {class: 'form-control', rows: 3}}) }}</div>
            <div class="col-md-3">{{ form_row(form.montantDepenseFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-3">{{ form_row(form.montantDemandeFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-3">{{ form_row(form.montantAccordeFiphfp, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-3">{{ form_row(form.accordPayeLe, {attr: {class: 'form-control'}}) }}</div>
            <div class="col-md-3">{{ form_row(form.urgenceFiphfp, {attr: {class: 'form-select'}}) }}</div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
            <a href="{{ path('app_fiphfp_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
