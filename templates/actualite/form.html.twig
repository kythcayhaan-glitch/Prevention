{% extends 'base.html.twig' %}
{% block title %}{{ actu ? 'Modifier' : 'Nouvelle' }} mise à jour{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-megaphone"></i> {{ actu ? 'Modifier la mise à jour' : 'Nouvelle mise à jour' }}</h2>
    <a href="{{ path('app_actualite_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form method="post" action="{{ actu ? path('app_actualite_edit', {id: actu.id}) : path('app_actualite_new') }}">
            <div class="mb-3">
                <label class="form-label fw-bold">Titre <small class="text-muted fw-normal">(optionnel)</small></label>
                <input type="text" name="titre" class="form-control" value="{{ actu ? actu.titre : '' }}" placeholder="Ex : Version 1.2, Correction bug…">
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Contenu <span class="text-danger">*</span></label>
                <textarea name="contenu" class="form-control" rows="6" required>{{ actu ? actu.contenu : '' }}</textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
                <a href="{{ path('app_actualite_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
