{% extends 'base.html.twig' %}
{% block title %}Mises à jour{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-megaphone"></i> Mises à jour</h2>
    <a href="{{ path('app_actualite_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ajouter</a>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if actualites is empty %}
            <p class="text-muted text-center py-5 mb-0"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucune mise à jour.</p>
        {% else %}
        <table class="table table-hover mb-0">
            <thead><tr><th>Date</th><th>Titre</th><th>Contenu</th><th></th></tr></thead>
            <tbody>
            {% for actu in actualites %}
            <tr>
                <td class="text-nowrap text-muted small">{{ actu.dateCreation|date('d/m/Y') }}</td>
                <td>{{ actu.titre ?? '—' }}</td>
                <td class="text-muted small">{{ actu.contenu|u.truncate(80, '…') }}</td>
                <td class="text-end text-nowrap">
                    <a href="{{ path('app_actualite_edit', {id: actu.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier"><i class="bi bi-pencil"></i></a>
                    <form method="post" action="{{ path('app_actualite_delete', {id: actu.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette mise à jour ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-actu-' ~ actu.id) }}">
                        <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endblock %}
