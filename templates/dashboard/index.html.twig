{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Tableau de bord</h2>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <a href="{{ path('app_visite_index') }}" class="text-decoration-none">
            <div class="card border-0 bg-primary text-white">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-clipboard-heart fs-1"></i>
                    <div>
                        <div class="fs-1 fw-bold">{{ nb_visites }}</div>
                        <div>Visites de prévention</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_rqth_index') }}" class="text-decoration-none">
            <div class="card border-0 bg-success text-white">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-person-badge fs-1"></i>
                    <div>
                        <div class="fs-1 fw-bold">{{ nb_rqth }}</div>
                        <div>Dossiers RQTH</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_fiphfp_index') }}" class="text-decoration-none">
            <div class="card border-0 bg-warning text-dark">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-cash-coin fs-1"></i>
                    <div>
                        <div class="fs-1 fw-bold">{{ nb_fiphfp }}</div>
                        <div>Demandes FIPHFP</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_inter_index') }}" class="text-decoration-none">
            <div class="card border-0 bg-danger text-white">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="bi bi-tools fs-1"></i>
                    <div>
                        <div class="fs-1 fw-bold">{{ nb_inter }}</div>
                        <div>Interventions</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-lightning-charge"></i> Actions rapides</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a href="{{ path('app_visite_new') }}" class="btn btn-primary"><i class="bi bi-plus"></i> Nouvelle visite</a>
                    <a href="{{ path('app_rqth_new') }}" class="btn btn-success"><i class="bi bi-plus"></i> Nouveau RQTH</a>
                    <a href="{{ path('app_fiphfp_new') }}" class="btn btn-warning"><i class="bi bi-plus"></i> FIPHFP</a>
                    <a href="{{ path('app_inter_new') }}" class="btn btn-danger"><i class="bi bi-plus"></i> Intervention</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle"></i> Informations</div>
            <div class="card-body">
                <p class="text-muted mb-1">Connecté en tant que : <strong>{{ app.user.nom }}</strong></p>
                <p class="text-muted mb-1">Profil : <strong>
                    {% if is_granted('ROLE_SUPER_ADMIN') %}Super Administrateur
                    {% elseif is_granted('ROLE_ADMIN') %}Administrateur
                    {% else %}Agent{% endif %}
                </strong></p>
                <p class="text-muted mb-0">Service : <strong>{{ app.user.service }}</strong></p>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-folder2-open"></i> Documents et formulaires</span>
        <button class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#formUpload">
            <i class="bi bi-upload"></i> Ajouter
        </button>
    </div>
    <div class="collapse" id="formUpload">
        <div class="card-body border-bottom">
            <form method="post" action="{{ path('app_document_upload') }}" enctype="multipart/form-data" class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label mb-1 small">Nom du document</label>
                    <input type="text" name="nom" class="form-control form-control-sm" placeholder="Laisser vide = nom du fichier" style="width:250px">
                </div>
                <div>
                    <label class="form-label mb-1 small">Fichier</label>
                    <input type="file" name="fichier" class="form-control form-control-sm" required>
                </div>
                <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-lg"></i> Enregistrer</button>
            </form>
        </div>
    </div>
    <div class="card-body p-0">
        {% if documents is empty %}
            <p class="text-muted text-center py-4 mb-0"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucun document.</p>
        {% else %}
        <table class="table table-hover mb-0">
            <thead><tr><th>Nom</th><th>Taille</th><th>Ajouté le</th><th></th></tr></thead>
            <tbody>
            {% for doc in documents %}
            <tr>
                <td><i class="bi bi-file-earmark me-1 text-muted"></i>{{ doc.nom }}</td>
                <td class="text-muted small">{{ doc.taille ? (doc.taille / 1024)|round ~ ' Ko' : '—' }}</td>
                <td class="text-muted small">{{ doc.dateAjout|date('d/m/Y') }}</td>
                <td class="text-end" onclick="event.stopPropagation()">
                    <a href="{{ path('app_document_download', {id: doc.id}) }}" class="btn btn-sm btn-outline-primary" title="Télécharger"><i class="bi bi-download"></i></a>
                    <form method="post" action="{{ path('app_document_delete', {id: doc.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce document ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-doc-' ~ doc.id) }}">
                        <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endblock %}
