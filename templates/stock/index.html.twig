{% extends 'base.html.twig' %}
{% block title %}Stock{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Stock</h2>
    <a href="{{ path('app_stock_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ajouter</a>
</div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0">
<thead><tr><th>#</th><th>Désignation</th><th>Réf</th><th>Prix</th><th>Stock mini</th><th>Stock réel</th><th>Donné</th><th>Actions</th></tr></thead>
<tbody>
{% for item in stocks %}
<tr>
    <td>{{ item.id }}</td><td>{{ item.designation }}</td><td>{{ item.ref }}</td>
    <td>{{ item.prix }} €</td><td>{{ item.stockMini }}</td>
    <td class="{{ item.stockReel is not null and item.stockMini is not null and item.stockReel <= item.stockMini ? 'text-danger fw-bold' : '' }}">{{ item.stockReel }}</td>
    <td>{{ item.donnee }}</td>
    <td>
        <a href="{{ path('app_stock_edit', {id: item.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
        <form method="post" action="{{ path('app_stock_delete', {id: item.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
        </form>
    </td>
</tr>
{% else %}<tr><td colspan="8" class="text-center text-muted py-4">Stock vide.</td></tr>{% endfor %}
</tbody></table></div></div>
{% endblock %}
