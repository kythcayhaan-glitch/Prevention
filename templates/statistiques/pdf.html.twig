<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; font-family: DejaVu Sans, Arial, sans-serif; font-size: 11px; }
body { color: #222; }

.page { width: 190mm; padding: 10mm; page-break-after: always; }
.page:last-child { page-break-after: auto; }

h1 { font-size: 18px; margin-bottom: 4px; }
h2 { font-size: 14px; margin: 12px 0 6px 0; padding: 4px 8px; color: #fff; border-radius: 3px; }
h2.green  { background: #27ae60; }
h2.yellow { background: #e67e22; color: #fff; }
h2.red    { background: #c0392b; }
h2.blue   { background: #2980b9; }

.subtitle { font-size: 10px; color: #666; margin-bottom: 10px; }
.date { font-size: 10px; color: #888; }

/* Alertes */
.alert { background: #fef9e7; border-left: 4px solid #e67e22; padding: 6px 8px; margin-bottom: 8px; font-size: 10px; }

/* Tableau */
table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
th { background: #ecf0f1; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 2px solid #bdc3c7; font-size: 10px; }
td { padding: 4px 6px; border-bottom: 1px solid #ecf0f1; font-size: 10px; }
tr:nth-child(even) td { background: #f9f9f9; }

/* Barres CSS */
.bar-row { display: flex; align-items: center; margin-bottom: 5px; }
.bar-label { width: 120px; font-size: 9px; overflow: hidden; white-space: nowrap; }
.bar-track { flex: 1; background: #ecf0f1; height: 14px; border-radius: 2px; margin: 0 6px; }
.bar-fill { height: 14px; border-radius: 2px; }
.bar-val { width: 30px; font-size: 9px; text-align: right; font-weight: bold; }

/* Camembert simulé par tableau coloré */
.pie-row { display: inline-block; margin: 3px 6px 3px 0; }
.pie-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 4px; vertical-align: middle; }

/* Grille 2 colonnes */
.grid2 { display: flex; gap: 10mm; }
.col { flex: 1; }

/* Montants */
.montant-box { background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 4px; padding: 8px; margin-bottom: 8px; }
.montant-row { display: flex; justify-content: space-between; padding: 3px 0; border-bottom: 1px solid #eee; }
.montant-row:last-child { border-bottom: none; font-weight: bold; }

.badge { display: inline-block; padding: 2px 6px; border-radius: 10px; font-size: 9px; font-weight: bold; }
.badge-success { background: #d5f5e3; color: #1e8449; }
.badge-warning { background: #fef9e7; color: #b7770d; }
.badge-danger  { background: #fadbd8; color: #922b21; }
.badge-secondary { background: #eaecee; color: #555; }
</style>
</head>
<body>

{# PAGE 1 : RQTH #}
<div class="page">
    <h1><span style="color:#27ae60">■</span> Statistiques — RQTH</h1>
    <div class="date">Généré le {{ "now"|date("d/m/Y") }}</div>

    {% if rqth_expiring is not empty %}
    <div class="alert" style="margin-top:8px">
        ⚠ {{ rqth_expiring|length }} RQTH expirant dans les 3 prochains mois
    </div>
    <table>
        <tr><th>Agent</th><th>Service</th><th>Date de fin</th></tr>
        {% for r in rqth_expiring %}
        <tr><td>{{ r.agentRqth }} {{ r.prenomRqth }}</td><td>{{ r.poleServiceRqth }}</td><td>{{ r.dateFinAttributionRqth }}</td></tr>
        {% endfor %}
    </table>
    {% endif %}

    <div class="grid2">
        <div class="col">
            <h2 class="green">Répartition par état</h2>
            {% set total_rqth = 0 %}{% for r in rqth_by_etat %}{% set total_rqth = total_rqth + r.total %}{% endfor %}
            {% set pie_colors = ['#27ae60','#2980b9','#e67e22','#c0392b','#8e44ad','#16a085'] %}
            {% for r in rqth_by_etat %}
            <div class="pie-row">
                <span class="pie-dot" style="background:{{ pie_colors[loop.index0 % pie_colors|length] }}"></span>
                {{ r.etat }} : <strong>{{ r.total }}</strong>
            </div>
            {% endfor %}
        </div>
        <div class="col">
            <h2 class="green">Total dossiers RQTH</h2>
            {% set total_rqth = 0 %}{% for r in rqth_by_etat %}{% set total_rqth = total_rqth + r.total %}{% endfor %}
            <div style="font-size:36px; font-weight:bold; color:#27ae60; text-align:center; margin-top:10px">{{ total_rqth }}</div>
            <div style="text-align:center; color:#888">dossiers</div>
        </div>
    </div>

    <h2 class="green" style="margin-top:10px">Par pôle / service (top 10)</h2>
    {% set max_s = max(rqth_by_service|map(r => r.total)) %}
    {% for r in rqth_by_service %}
    <div class="bar-row">
        <div class="bar-label" title="{{ r.service }}">{{ r.service|slice(0,22) }}</div>
        <div class="bar-track"><div class="bar-fill" style="width:{{ max_s > 0 ? (r.total/max_s*100)|round : 0 }}%; background:#27ae60"></div></div>
        <div class="bar-val">{{ r.total }}</div>
    </div>
    {% endfor %}
</div>

{# PAGE 2 : FIPHFP #}
<div class="page">
    <h1><span style="color:#e67e22">■</span> Statistiques — FIPHFP</h1>
    <div class="date">Généré le {{ "now"|date("d/m/Y") }}</div>

    <div class="grid2">
        <div class="col">
            <h2 class="yellow">Répartition par état</h2>
            {% set pie_colors = ['#27ae60','#2980b9','#c0392b','#8e44ad','#e67e22'] %}
            {% for f in fiphfp_by_etat %}
            <div class="pie-row">
                <span class="pie-dot" style="background:{{ pie_colors[loop.index0 % pie_colors|length] }}"></span>
                {{ f.etat }} : <strong>{{ f.total }}</strong>
            </div>
            {% endfor %}
        </div>
        <div class="col">
            <h2 class="yellow">Montants globaux</h2>
            <div class="montant-box">
                <div class="montant-row"><span>Montant dépensé</span><strong>{{ fiphfp_montants.depense|default(0)|number_format(0, ',', ' ') }} €</strong></div>
                <div class="montant-row"><span>Montant accordé</span><strong>{{ fiphfp_montants.accorde|default(0)|number_format(0, ',', ' ') }} €</strong></div>
                <div class="montant-row"><span>Reste à charge total</span><strong>{{ fiphfp_montants.reste|default(0)|number_format(0, ',', ' ') }} €</strong></div>
            </div>
        </div>
    </div>

    <div class="grid2">
        <div class="col">
            <h2 class="yellow">Reste à charge — bénéficiaire</h2>
            {% set pie_colors = ['#2980b9','#e67e22'] %}
            {% for f in fiphfp_by_reste %}
            <div class="pie-row">
                <span class="pie-dot" style="background:{{ pie_colors[loop.index0 % 2] }}"></span>
                {{ f.type == 'agent' ? "L'agent" : 'Collectivité' }} : <strong>{{ f.total }}</strong> dossiers
                {% if f.montant %} / {{ f.montant|number_format(0,',', ' ') }} €{% endif %}
            </div>
            {% endfor %}
        </div>
        <div class="col">
            <h2 class="yellow">Top 5 objets de demande</h2>
            {% set max_o = max(fiphfp_objets|map(o => o.total)) %}
            {% for o in fiphfp_objets %}
            <div class="bar-row">
                <div class="bar-label" title="{{ o.objet }}">{{ o.objet|slice(0,22) }}</div>
                <div class="bar-track"><div class="bar-fill" style="width:{{ max_o > 0 ? (o.total/max_o*100)|round : 0 }}%; background:#e67e22"></div></div>
                <div class="bar-val">{{ o.total }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{# PAGE 3 : INTERVENTIONS #}
<div class="page">
    <h1><span style="color:#c0392b">■</span> Statistiques — Interventions</h1>
    <div class="date">Généré le {{ "now"|date("d/m/Y") }}</div>

    <div class="grid2">
        <div class="col">
            <h2 class="red">Par urgence</h2>
            {% set urgence_labels = {'a_traiter': 'A traiter', 'en_cours': 'En cours', 'traite': 'Traité'} %}
            {% set urgence_colors = {'a_traiter': '#c0392b', 'en_cours': '#e67e22', 'traite': '#27ae60'} %}
            {% for i in inter_by_urgence %}
            <div class="pie-row">
                <span class="pie-dot" style="background:{{ urgence_colors[i.urgence] ?? '#888' }}"></span>
                {{ urgence_labels[i.urgence] ?? i.urgence }} : <strong>{{ i.total }}</strong>
            </div>
            {% endfor %}
        </div>
        <div class="col">
            <h2 class="red">Top 5 agents concernés</h2>
            {% set max_a = max(inter_top_agents|map(a => a.total)) %}
            {% for a in inter_top_agents %}
            <div class="bar-row">
                <div class="bar-label">{{ a.agent|slice(0,20) }}</div>
                <div class="bar-track"><div class="bar-fill" style="width:{{ max_a > 0 ? (a.total/max_a*100)|round : 0 }}%; background:#c0392b"></div></div>
                <div class="bar-val">{{ a.total }}</div>
            </div>
            {% endfor %}
        </div>
    </div>

    <h2 class="red" style="margin-top:10px">Évolution mensuelle (12 derniers mois)</h2>
    {% set max_m = max(inter_by_month) %}
    {% for mois, nb in inter_by_month %}
    <div class="bar-row">
        <div class="bar-label">{{ mois }}</div>
        <div class="bar-track"><div class="bar-fill" style="width:{{ max_m > 0 ? (nb/max_m*100)|round : 0 }}%; background:#e74c3c"></div></div>
        <div class="bar-val">{{ nb }}</div>
    </div>
    {% endfor %}

    <h2 class="red" style="margin-top:10px">Par service (top 10)</h2>
    {% set max_sv = max(inter_by_service|map(i => i.total)) %}
    {% for i in inter_by_service %}
    <div class="bar-row">
        <div class="bar-label">{{ i.service|slice(0,22) }}</div>
        <div class="bar-track"><div class="bar-fill" style="width:{{ max_sv > 0 ? (i.total/max_sv*100)|round : 0 }}%; background:#c0392b"></div></div>
        <div class="bar-val">{{ i.total }}</div>
    </div>
    {% endfor %}
</div>

</body>
</html>
