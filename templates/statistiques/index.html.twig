{% extends 'base.html.twig' %}
{% block title %}Statistiques{% endblock %}

{% block stylesheets %}
<style>
.stat-card { border: none; border-radius: 8px; }
.stat-card .card-header { font-weight: 600; border-radius: 8px 8px 0 0; }
.chart-container { position: relative; height: 220px; }
.alert-expiring { border-left: 4px solid #e67e22; }
</style>
{% endblock %}

{% block body %}
<h2 class="mb-4"><i class="bi bi-bar-chart-line"></i> Statistiques</h2>

{# ALERTES #}
{% if rqth_expiring is not empty %}
<div class="alert alert-warning alert-expiring mb-4">
    <strong><i class="bi bi-exclamation-triangle me-1"></i> {{ rqth_expiring|length }} RQTH expirant dans les 3 prochains mois</strong>
    <ul class="mb-0 mt-2">
        {% for r in rqth_expiring %}
        <li><a href="{{ path('app_rqth_show', {id: r.id}) }}" class="text-dark">{{ r.agentRqth }} {{ r.prenomRqth }}</a> — expire le {{ r.dateFinAttributionRqth }}</li>
        {% endfor %}
    </ul>
</div>
{% endif %}

{# RQTH #}
<h4 class="mb-3 mt-2"><i class="bi bi-person-badge text-success me-2"></i>RQTH</h4>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-success text-white">Répartition par état</div>
            <div class="card-body"><div class="chart-container"><canvas id="rqthEtat"></canvas></div></div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-success text-white">Par pôle / service (top 10)</div>
            <div class="card-body"><div class="chart-container"><canvas id="rqthService"></canvas></div></div>
        </div>
    </div>
</div>

{# FIPHFP #}
<h4 class="mb-3"><i class="bi bi-cash-coin text-warning me-2"></i>FIPHFP</h4>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-warning text-dark">Répartition par état</div>
            <div class="card-body"><div class="chart-container"><canvas id="fiphfpEtat"></canvas></div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-warning text-dark">Montants globaux (€)</div>
            <div class="card-body d-flex flex-column justify-content-center gap-2">
                <div class="d-flex justify-content-between"><span>Dépensé</span><strong>{{ fiphfp_montants.depense|default(0)|number_format(0, ',', ' ') }} €</strong></div>
                <div class="d-flex justify-content-between"><span>Accordé</span><strong>{{ fiphfp_montants.accorde|default(0)|number_format(0, ',', ' ') }} €</strong></div>
                <div class="d-flex justify-content-between border-top pt-2"><span>Reste à charge</span><strong>{{ fiphfp_montants.reste|default(0)|number_format(0, ',', ' ') }} €</strong></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-warning text-dark">Reste à charge pour</div>
            <div class="card-body"><div class="chart-container"><canvas id="fiphfpReste"></canvas></div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-warning text-dark">Top 5 objets</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    {% for o in fiphfp_objets %}
                    <tr><td class="small">{{ o.objet }}</td><td class="text-end fw-bold">{{ o.total }}</td></tr>
                    {% endfor %}
                </table>
            </div>
        </div>
    </div>
</div>

{# INTERVENTIONS #}
<h4 class="mb-3"><i class="bi bi-tools text-danger me-2"></i>Interventions</h4>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-danger text-white">Par urgence</div>
            <div class="card-body"><div class="chart-container"><canvas id="interUrgence"></canvas></div></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-danger text-white">Top 5 agents concernés</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    {% for a in inter_top_agents %}
                    <tr><td class="small">{{ a.agent }}</td><td class="text-end fw-bold">{{ a.total }}</td></tr>
                    {% endfor %}
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-danger text-white">Évolution mensuelle (12 derniers mois)</div>
            <div class="card-body"><div class="chart-container"><canvas id="interMonth"></canvas></div></div>
        </div>
    </div>
    <div class="col-12">
        <div class="card stat-card shadow-sm">
            <div class="card-header bg-danger text-white">Par service (top 10)</div>
            <div class="card-body"><div class="chart-container" style="height:180px"><canvas id="interService"></canvas></div></div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
const COLORS = ['#27ae60','#2980b9','#8e44ad','#e67e22','#c0392b','#16a085','#f39c12','#2c3e50','#1abc9c','#e74c3c'];

function pie(id, labels, data) {
    new Chart(document.getElementById(id), {
        type: 'doughnut',
        data: { labels, datasets: [{ data, backgroundColor: COLORS }] },
        options: { plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } }, maintainAspectRatio: false }
    });
}
function bar(id, labels, data, color) {
    new Chart(document.getElementById(id), {
        type: 'bar',
        data: { labels, datasets: [{ data, backgroundColor: color || '#2980b9', borderRadius: 4 }] },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, maintainAspectRatio: false }
    });
}
function line(id, labels, data) {
    new Chart(document.getElementById(id), {
        type: 'line',
        data: { labels, datasets: [{ data, borderColor: '#c0392b', backgroundColor: 'rgba(192,57,43,.1)', fill: true, tension: .3, pointRadius: 4 }] },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, maintainAspectRatio: false }
    });
}

// RQTH
pie('rqthEtat',
    [{% for r in rqth_by_etat %}'{{ r.etat }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for r in rqth_by_etat %}{{ r.total }}{% if not loop.last %},{% endif %}{% endfor %}]
);
bar('rqthService',
    [{% for r in rqth_by_service %}'{{ r.service|slice(0,20) }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for r in rqth_by_service %}{{ r.total }}{% if not loop.last %},{% endif %}{% endfor %}],
    '#27ae60'
);

// FIPHFP
pie('fiphfpEtat',
    [{% for f in fiphfp_by_etat %}'{{ f.etat }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for f in fiphfp_by_etat %}{{ f.total }}{% if not loop.last %},{% endif %}{% endfor %}]
);
pie('fiphfpReste',
    [{% for f in fiphfp_by_reste %}'{{ f.type == 'agent' ? "L'agent" : 'Collectivité' }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for f in fiphfp_by_reste %}{{ f.total }}{% if not loop.last %},{% endif %}{% endfor %}]
);

// Interventions
const urgenceLabels = {'a_traiter': 'A traiter', 'en_cours': 'En cours', 'traite': 'Traité'};
pie('interUrgence',
    [{% for i in inter_by_urgence %}'{{ i.urgence }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for i in inter_by_urgence %}{{ i.total }}{% if not loop.last %},{% endif %}{% endfor %}]
);
bar('interService',
    [{% for i in inter_by_service %}'{{ i.service|slice(0,20) }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for i in inter_by_service %}{{ i.total }}{% if not loop.last %},{% endif %}{% endfor %}],
    '#c0392b'
);
line('interMonth',
    [{% for k, v in inter_by_month %}'{{ k }}'{% if not loop.last %},{% endif %}{% endfor %}],
    [{% for k, v in inter_by_month %}{{ v }}{% if not loop.last %},{% endif %}{% endfor %}]
);
</script>
{% endblock %}
