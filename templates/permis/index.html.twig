{% extends 'base.html.twig' %}
{% block title %}Permis de conduire{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ app.request.basePath }}/css/permis.css">
{% endblock %}

{% macro date_cell(date, status) %}
    {% if date %}
        {% if status == 'expired' %}
            <span class="badge-expired">{{ date }}</span>
        {% elseif status == 'soon' %}
            <span class="badge-soon">{{ date }}</span>
        {% else %}
            <span class="badge-ok">{{ date }}</span>
        {% endif %}
    {% else %}
        <span class="badge-none">—</span>
    {% endif %}
{% endmacro %}

{# ── Collecte des alertes "soon" (hors bloc pour être accessible partout) ── #}
{% set alerts = [] %}
{% for p in permis %}
    {% set name = p.nom ~ (p.prenom ? ' ' ~ p.prenom) %}
    {% if p.permisCValidite|date_status == 'soon' %}
        {% set alerts = alerts|merge([{name: name, label: 'Permis C — Validité', date: p.permisCValidite}]) %}
    {% endif %}
    {% if p.permisDValidite|date_status == 'soon' %}
        {% set alerts = alerts|merge([{name: name, label: 'Permis D — Validité', date: p.permisDValidite}]) %}
    {% endif %}
    {% if p.permisEValidite|date_status == 'soon' %}
        {% set alerts = alerts|merge([{name: name, label: 'Permis E — Validité', date: p.permisEValidite}]) %}
    {% endif %}
    {% if p.fimoProchaine|date_status == 'soon' %}
        {% set alerts = alerts|merge([{name: name, label: 'FIMO — Prochaine', date: p.fimoProchaine}]) %}
    {% endif %}
    {% if p.fcoProchaine|date_status == 'soon' %}
        {% set alerts = alerts|merge([{name: name, label: 'FCO — Prochaine', date: p.fcoProchaine}]) %}
    {% endif %}
    {% if p.visiteMedicaleProchaine|date_status == 'soon' %}
        {% set alerts = alerts|merge([{name: name, label: 'Visite médicale', date: p.visiteMedicaleProchaine}]) %}
    {% endif %}
{% endfor %}

{% block body %}

{# ── Modale alertes ── #}
{% if alerts|length > 0 %}
<div class="modal fade" id="modalAlertes" tabindex="-1" aria-labelledby="modalAlertesLabel" aria-modal="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background:#fd7e14;color:#fff">
                <h5 class="modal-title" id="modalAlertesLabel">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    {{ alerts|length }} échéance(s) dans moins de 3 mois
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Agent</th>
                            <th>Rubrique</th>
                            <th>Échéance</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for a in alerts %}
                        <tr>
                            <td><strong>{{ a.name }}</strong></td>
                            <td>{{ a.label }}</td>
                            <td><span class="badge-soon">{{ a.date }}</span></td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# ── Modale convocation ── #}
<div class="modal fade" id="modalConvocation" tabindex="-1" aria-labelledby="modalConvocationLabel" aria-modal="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:#b71c1c;color:#fff">
                <h5 class="modal-title" id="modalConvocationLabel">
                    <i class="bi bi-file-earmark-pdf"></i> Convocation — <span id="convNom"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="formConvocation" method="post" target="_blank">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Permis concerné(s)</label>
                        <div class="d-flex gap-4">
                            <div class="form-check" id="wrap-c">
                                <input class="form-check-input" type="checkbox" name="types[]" value="C" id="chk-c">
                                <label class="form-check-label" for="chk-c">Permis C</label>
                            </div>
                            <div class="form-check" id="wrap-d">
                                <input class="form-check-input" type="checkbox" name="types[]" value="D" id="chk-d">
                                <label class="form-check-label" for="chk-d">Permis D</label>
                            </div>
                            <div class="form-check" id="wrap-e">
                                <input class="form-check-input" type="checkbox" name="types[]" value="E" id="chk-e">
                                <label class="form-check-label" for="chk-e">Permis E</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Formations</label>
                        <div class="d-flex gap-4">
                            <div class="form-check" id="wrap-fimo">
                                <input class="form-check-input" type="checkbox" name="types[]" value="FIMO" id="chk-fimo">
                                <label class="form-check-label" for="chk-fimo">FIMO</label>
                            </div>
                            <div class="form-check" id="wrap-fco">
                                <input class="form-check-input" type="checkbox" name="types[]" value="FCO" id="chk-fco">
                                <label class="form-check-label" for="chk-fco">FCO</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Date du rendez-vous</label>
                        <input type="text" name="date" id="convDate" class="form-control date-picker" placeholder="JJ/MM/AAAA" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold">Heure</label>
                        <input type="time" name="heure" class="form-control" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-file-earmark-pdf"></i> Générer le PDF
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="medecin-contact">
    <i class="bi bi-telephone-fill"></i>
    Médecin agréé — Dr CHEVALIER : <strong>03.21.31.78.09</strong>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-card-checklist"></i> Permis de conduire</h4>
    <div class="d-flex align-items-center gap-3">
        <input type="text" id="search" class="form-control table-search" placeholder="Rechercher un agent…" style="width:220px">
        {% if alerts|length > 0 %}
        <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#modalAlertes">
            <i class="bi bi-exclamation-triangle-fill"></i> {{ alerts|length }} alerte(s)
        </button>
        {% endif %}
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_permis_new') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Ajouter
        </a>
        {% endif %}
    </div>
</div>

{# Légende #}
<div class="mb-2 d-flex gap-3" style="font-size:.78rem">
    <span><span class="badge-expired">date</span> Expiré</span>
    <span><span class="badge-soon">date</span> &lt; 3 mois</span>
    <span><span class="badge-ok">date</span> OK</span>
    <span><span class="badge-none">—</span> Non renseigné</span>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0" style="overflow-x:auto">
        <table class="table table-hover table-bordered mb-0 permis-table" id="permisTable">
            <thead>
                <tr>
                    <th rowspan="2">Agent</th>
                    <th colspan="2" class="group-header" style="background:#1565c0">Permis C</th>
                    <th colspan="2" class="group-header" style="background:#283593">Permis D</th>
                    <th colspan="2" class="group-header" style="background:#4527a0">Permis E</th>
                    <th colspan="2" class="group-header" style="background:#2e7d32">FIMO</th>
                    <th colspan="3" class="group-header" style="background:#1b5e20">FCO</th>
                    <th colspan="2" class="group-header" style="background:#b71c1c">Visite médicale</th>
                    <th rowspan="2"></th>
                </tr>
                <tr>
                    <th>Obtention</th><th>Validité</th>
                    <th>Obtention</th><th>Validité</th>
                    <th>Obtention</th><th>Validité</th>
                    <th>Obtention</th><th>Prochaine</th>
                    <th>Type</th><th>Obtention</th><th>Prochaine</th>
                    <th>Réalisée</th><th>Prochaine</th>
                </tr>
            </thead>
            <tbody>
            {% for p in permis %}
                <tr class="permis-row" {% if is_granted('ROLE_ADMIN') %}data-href="{{ path('app_permis_edit', {id: p.id}) }}"{% endif %}>
                    <td><strong>{{ p.nom }}</strong>{% if p.prenom %} {{ p.prenom }}{% endif %}</td>
                    {# Permis C #}
                    <td>{{ _self.date_cell(p.permisCObtention, p.permisCObtention|date_status) }}</td>
                    <td>{{ _self.date_cell(p.permisCValidite, p.permisCValidite|date_status) }}</td>
                    {# Permis D #}
                    <td>{{ _self.date_cell(p.permisDObtention, p.permisDObtention|date_status) }}</td>
                    <td>{{ _self.date_cell(p.permisDValidite, p.permisDValidite|date_status) }}</td>
                    {# Permis E #}
                    <td>{{ _self.date_cell(p.permisEObtention, p.permisEObtention|date_status) }}</td>
                    <td>{{ _self.date_cell(p.permisEValidite, p.permisEValidite|date_status) }}</td>
                    {# FIMO #}
                    <td>{{ _self.date_cell(p.fimoObtention, null) }}</td>
                    <td>{{ _self.date_cell(p.fimoProchaine, p.fimoProchaine|date_status) }}</td>
                    {# FCO #}
                    <td>
                        {% if p.fimoType %}
                            <span class="fimo-type">{{ p.fimoType }}</span>
                        {% else %}
                            <span class="badge-none">—</span>
                        {% endif %}
                    </td>
                    <td>{{ _self.date_cell(p.fcoObtention, null) }}</td>
                    <td>{{ _self.date_cell(p.fcoProchaine, p.fcoProchaine|date_status) }}</td>
                    {# Visite médicale #}
                    <td>{{ _self.date_cell(p.visiteMedicaleRealisee, null) }}</td>
                    <td>{{ _self.date_cell(p.visiteMedicaleProchaine, p.visiteMedicaleProchaine|date_status) }}</td>
                    {# Actions #}
                    <td onclick="event.stopPropagation()">
                        {% if is_granted('ROLE_ADMIN') %}
                        <button type="button" class="btn btn-outline-danger btn-sm btn-convocation"
                            title="Convocation"
                            data-url="{{ path('app_permis_convocation', {id: p.id}) }}"
                            data-nom="{{ p.genre ? p.genre ~ ' ' }}{{ p.nomComplet }}"
                            data-has-c="{{ p.permisCObtention ? '1' : '0' }}"
                            data-has-d="{{ p.permisDObtention ? '1' : '0' }}"
                            data-has-e="{{ p.permisEObtention ? '1' : '0' }}"
                            data-status-c="{{ p.permisCValidite|date_status }}"
                            data-status-d="{{ p.permisDValidite|date_status }}"
                            data-status-e="{{ p.permisEValidite|date_status }}"
                            data-has-fimo="{{ p.fimoProchaine ? '1' : '0' }}"
                            data-status-fimo="{{ p.fimoProchaine|date_status }}"
                            data-has-fco="{{ p.fcoProchaine ? '1' : '0' }}"
                            data-status-fco="{{ p.fcoProchaine|date_status }}"
                            data-bs-toggle="modal" data-bs-target="#modalConvocation">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </button>
                        <form method="post" action="{{ path('app_permis_delete', {id: p.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet agent ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ p.id) }}">
                            <button class="btn btn-outline-secondary btn-sm" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="16" class="text-center text-muted py-4">Aucun agent enregistré.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
<div class="mt-2 text-muted small">{{ permis|length }} agent(s)</div>

{# ── Documents ── #}
<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-folder2-open"></i> Documents</span>
        {% if is_granted('ROLE_ADMIN') %}
        <button class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#formUploadPermis">
            <i class="bi bi-upload"></i> Ajouter
        </button>
        {% endif %}
    </div>
    {% if is_granted('ROLE_ADMIN') %}
    <div class="collapse" id="formUploadPermis">
        <div class="card-body border-bottom">
            <form method="post" action="{{ path('app_permis_doc_upload') }}" enctype="multipart/form-data" class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label mb-1 small">Nom du document</label>
                    <input type="text" name="nom" class="form-control form-control-sm" placeholder="Laisser vide = nom du fichier" style="width:250px">
                </div>
                <div>
                    <label class="form-label mb-1 small">Fichier</label>
                    <input type="file" name="fichier" class="form-control form-control-sm" required>
                </div>
                <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-lg"></i> Enregistrer</button>
            </form>
        </div>
    </div>
    {% endif %}
    <div class="card-body p-0">
        {% if documents is empty %}
            <p class="text-muted text-center py-4 mb-0"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucun document.</p>
        {% else %}
        <table class="table table-hover mb-0">
            <thead><tr><th>Nom</th><th>Taille</th><th>Ajouté le</th><th></th></tr></thead>
            <tbody>
            {% for doc in documents %}
            {% set ext = doc.nomFichier|split('.')|last|lower %}
            {% set icon = 'bi-file-earmark' %}{% set iconColor = 'text-secondary' %}
            {% if ext in ['pdf'] %}{% set icon = 'bi-file-earmark-pdf' %}{% set iconColor = 'text-danger' %}
            {% elseif ext in ['doc','docx'] %}{% set icon = 'bi-file-earmark-word' %}{% set iconColor = 'text-primary' %}
            {% elseif ext in ['xls','xlsx'] %}{% set icon = 'bi-file-earmark-excel' %}{% set iconColor = 'text-success' %}
            {% elseif ext in ['jpg','jpeg','png','gif'] %}{% set icon = 'bi-file-earmark-image' %}{% set iconColor = 'text-warning' %}
            {% elseif ext in ['zip','rar','7z'] %}{% set icon = 'bi-file-earmark-zip' %}{% set iconColor = 'text-dark' %}
            {% endif %}
            <tr style="cursor:pointer" onclick="window.open('{{ path('app_permis_doc_download', {id: doc.id}) }}', '_blank')">
                <td><i class="bi {{ icon }} {{ iconColor }} me-1 fs-5"></i>{{ doc.nom }} <span class="badge bg-secondary ms-1" style="font-size:.7rem">{{ ext|upper }}</span></td>
                <td class="text-muted small">{{ doc.taille ? (doc.taille / 1024)|round ~ ' Ko' : '—' }}</td>
                <td class="text-muted small">{{ doc.dateAjout|date('d/m/Y') }}</td>
                <td class="text-end" onclick="event.stopPropagation()">
                    <a href="{{ path('app_permis_doc_download', {id: doc.id}) }}" target="_blank" class="btn btn-sm btn-outline-primary" title="Ouvrir"><i class="bi bi-box-arrow-up-right"></i></a>
                    {% if is_granted('ROLE_ADMIN') %}
                    <form method="post" action="{{ path('app_permis_doc_delete', {id: doc.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce document ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-doc-' ~ doc.id) }}">
                        <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.getElementById('search').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    document.querySelectorAll('#permisTable .permis-row').forEach(function (row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});
{% if alerts|length > 0 %}
document.addEventListener('DOMContentLoaded', function () {
    new bootstrap.Modal(document.getElementById('modalAlertes')).show();
});
{% endif %}

document.querySelectorAll('.btn-convocation').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.getElementById('formConvocation').action = this.dataset.url;
        document.getElementById('convNom').textContent = this.dataset.nom;
        document.getElementById('convDate').value = '';
        if (window._flatpickrConv) window._flatpickrConv.clear();

        ['C', 'D', 'E'].forEach(function (t) {
            var key = t.toLowerCase();
            var has    = btn.dataset['has' + t] === '1';
            var status = btn.dataset['status' + t];
            var wrap   = document.getElementById('wrap-' + key);
            var chk    = document.getElementById('chk-' + key);
            wrap.style.display = has ? '' : 'none';
            chk.checked  = has && (status === 'expired' || status === 'soon');
            chk.disabled = !has;
        });

        [{id: 'fimo', attr: 'Fimo'}, {id: 'fco', attr: 'Fco'}].forEach(function (item) {
            var has    = btn.dataset['has' + item.attr] === '1';
            var status = btn.dataset['status' + item.attr];
            var wrap   = document.getElementById('wrap-' + item.id);
            var chk    = document.getElementById('chk-' + item.id);
            wrap.style.display = has ? '' : 'none';
            chk.checked  = has && (status === 'expired' || status === 'soon');
            chk.disabled = !has;
        });
    });
});
document.addEventListener('DOMContentLoaded', function () {
    window._flatpickrConv = flatpickr('#convDate', { locale: 'fr', dateFormat: 'd/m/Y', allowInput: true });
});
</script>
{% endblock %}
