{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ app.request.basePath }}/css/permis.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-card-checklist"></i> {{ title }}</h4>
    <a href="{{ path('app_permis_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

{# Agent #}
<p class="permis-section-title" style="background:#1565c0">Agent</p>
<div class="permis-section-body">
    <div class="permis-grid-3">
        <div>
            <div class="permis-label">Genre</div>
            {{ form_widget(form.genre) }}
        </div>
        <div>
            <div class="permis-label">Nom</div>
            {{ form_widget(form.nom) }}
            {{ form_errors(form.nom) }}
        </div>
        <div>
            <div class="permis-label">Prénom</div>
            {{ form_widget(form.prenom) }}
        </div>
    </div>
</div>

{# Permis C / D / E #}
<p class="permis-section-title" style="background:#283593">Permis</p>
<div class="permis-section-body">
    <div class="permis-grid-3">
        <div>
            <div class="permis-label" style="color:#1565c0">Permis C — Obtention</div>
            {{ form_widget(form.permisCObtention) }}
        </div>
        <div>
            <div class="permis-label" style="color:#1565c0">Permis C — Validité</div>
            {{ form_widget(form.permisCValidite) }}
        </div>
        <div></div>
        <div>
            <div class="permis-label" style="color:#283593">Permis D — Obtention</div>
            {{ form_widget(form.permisDObtention) }}
        </div>
        <div>
            <div class="permis-label" style="color:#283593">Permis D — Validité</div>
            {{ form_widget(form.permisDValidite) }}
        </div>
        <div></div>
        <div>
            <div class="permis-label" style="color:#4527a0">Permis E — Obtention</div>
            {{ form_widget(form.permisEObtention) }}
        </div>
        <div>
            <div class="permis-label" style="color:#4527a0">Permis E — Validité</div>
            {{ form_widget(form.permisEValidite) }}
        </div>
        <div></div>
    </div>
</div>

{# FIMO / FCO #}
<p class="permis-section-title" style="background:#2e7d32">Formations (FIMO / FCO)</p>
<div class="permis-section-body">
    <div class="permis-grid-3">
        <div>
            <div class="permis-label">FIMO — Type</div>
            {{ form_widget(form.fimoType) }}
        </div>
        <div>
            <div class="permis-label">FIMO — Obtention (MM/AAAA)</div>
            {{ form_widget(form.fimoObtention) }}
        </div>
        <div>
            <div class="permis-label">FIMO — Prochaine (MM/AAAA)</div>
            {{ form_widget(form.fimoProchaine) }}
        </div>
        <div></div>
        <div>
            <div class="permis-label">FCO — Obtention (MM/AAAA)</div>
            {{ form_widget(form.fcoObtention) }}
        </div>
        <div>
            <div class="permis-label">FCO — Prochaine (MM/AAAA)</div>
            {{ form_widget(form.fcoProchaine) }}
        </div>
    </div>
</div>

{# Visite médicale #}
<p class="permis-section-title" style="background:#b71c1c">Visite médicale</p>
<div class="permis-section-body">
    <div class="permis-grid">
        <div>
            <div class="permis-label">Réalisée le (MM/AAAA)</div>
            {{ form_widget(form.visiteMedicaleRealisee) }}
        </div>
        <div>
            <div class="permis-label">Prochaine (MM/AAAA)</div>
            {{ form_widget(form.visiteMedicaleProchaine) }}
        </div>
    </div>
</div>

{# Notes #}
<p class="permis-section-title" style="background:#546e7a">Notes</p>
<div class="permis-section-body">
    {{ form_widget(form.notes) }}
</div>

{# Documents — uniquement en modification #}
{% if permis %}
<p class="permis-section-title" style="background:#37474f">Documents</p>
<div class="permis-section-body">
    {% if permis.agentDocuments is not empty %}
    <table class="table table-sm table-bordered mb-3">
        <thead class="table-light">
            <tr>
                <th>Nom</th>
                <th>Taille</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for doc in permis.agentDocuments %}
            <tr>
                <td>
                    <a href="{{ path('app_permis_doc_download', {id: doc.id}) }}" target="_blank">
                        <i class="bi bi-file-earmark"></i> {{ doc.nom }}
                    </a>
                </td>
                <td>{{ doc.taille ? (doc.taille / 1024)|round ~ ' Ko' : '—' }}</td>
                <td>{{ doc.dateAjout|date('d/m/Y') }}</td>
                <td>
                    <form method="post" action="{{ path('app_permis_agent_doc_delete', {permisId: permis.id, docId: doc.id}) }}"
                          onsubmit="return confirm('Supprimer ce document ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-agent-doc-' ~ doc.id) }}">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p class="text-muted small mb-3">Aucun document.</p>
    {% endif %}

    <form method="post" enctype="multipart/form-data"
          action="{{ path('app_permis_agent_doc_upload', {id: permis.id}) }}">
        <div class="d-flex gap-2 align-items-end">
            <div>
                <label class="form-label form-label-sm mb-1">Nom (optionnel)</label>
                <input type="text" name="nom" class="form-control form-control-sm" placeholder="Nom du document">
            </div>
            <div>
                <label class="form-label form-label-sm mb-1">Fichier</label>
                <input type="file" name="fichier" class="form-control form-control-sm" required>
            </div>
            <div>
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-upload"></i> Ajouter
                </button>
            </div>
        </div>
    </form>
</div>
{% endif %}

<div style="position:sticky;bottom:0;background:var(--theme-body-bg);padding:.75rem 0;border-top:1px solid var(--theme-card-border);z-index:10">
    <button type="submit" class="btn btn-primary btn-sm px-4">
        <i class="bi bi-floppy"></i> Enregistrer
    </button>
    <a href="{{ path('app_permis_index') }}" class="btn btn-outline-secondary btn-sm ms-2">Annuler</a>
    {% if permis %}
    <button type="button" class="btn btn-outline-danger btn-sm float-end" onclick="document.getElementById('form-delete-permis').submit()">
        <i class="bi bi-trash"></i> Supprimer
    </button>
    {% endif %}
</div>

{{ form_end(form) }}

{% if permis %}
<form id="form-delete-permis" method="post" action="{{ path('app_permis_delete', {id: permis.id}) }}" onsubmit="return confirm('Supprimer cet agent ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ permis.id) }}">
</form>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/index.js"></script>
<script>
(function () {
    var fn = '{{ form.vars.name }}';
    var autoPairs = {};
    autoPairs[fn + '[fimoObtention]'] = fn + '[fimoProchaine]';
    autoPairs[fn + '[fcoObtention]']  = fn + '[fcoProchaine]';

    var instances = {};

    document.querySelectorAll('.month-picker').forEach(function (el) {
        instances[el.name] = flatpickr(el, {
            locale: 'fr',
            plugins: [new monthSelectPlugin({ dateFormat: 'm/Y', shorthand: false })],
            onChange: function (dates, dateStr, fp) {
                var tgtName = autoPairs[fp.element.name];
                if (tgtName && dates.length > 0 && instances[tgtName]) {
                    var d = new Date(dates[0]);
                    d.setFullYear(d.getFullYear() + 5);
                    instances[tgtName].setDate(d, true);
                }
            }
        });
    });
}());
</script>
{% endblock %}
