{% extends 'base.html.twig' %}
{% block title %}Convocation — {{ permis.nomComplet }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-file-earmark-pdf"></i> Convocation visite médicale</h4>
    <a href="{{ path('app_permis_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

<div class="card shadow-sm" style="max-width:480px">
    <div class="card-header" style="background:#b71c1c;color:#fff">
        <strong>{{ permis.genre ? permis.genre ~ ' ' }}{{ permis.nomComplet }}</strong>
    </div>
    <div class="card-body">
        <form method="post" action="{{ path('app_permis_convocation', {id: permis.id}) }}" target="_blank">
            <div class="mb-3">
                <label class="form-label fw-semibold">Date du rendez-vous</label>
                <input type="text" name="date" class="form-control date-picker" placeholder="JJ/MM/AAAA" required>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Heure</label>
                <input type="time" name="heure" class="form-control" required>
            </div>
            <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-file-earmark-pdf"></i> Générer la convocation PDF
            </button>
        </form>
    </div>
</div>
{% endblock %}
