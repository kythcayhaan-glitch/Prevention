{% extends 'base.html.twig' %}
{% block title %}Visite {{ visite.agentVisite }} {{ visite.prenomVisite }}{% endblock %}
{% block stylesheets %}
<style>
    dl.row dt, dl.row dd { margin-bottom: 0; padding-top: .05rem; padding-bottom: .05rem; }
</style>
{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-heart"></i> Visite de prévention – {{ visite.agentVisite }} {{ visite.prenomVisite }}</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('app_visite_edit', {id: visite.id}) }}" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Planifier les visites médicales</a>
        <a href="{{ path('app_visite_fiche_suivi', {id: visite.id}) }}" class="btn btn-success"><i class="bi bi-file-medical"></i> Fiche de suivi</a>
        <a href="{{ path('app_visite_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">Informations générales</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Genre</dt><dd class="col-sm-7">{{ visite.genre }}</dd>
                    <dt class="col-sm-5">Nom</dt><dd class="col-sm-7"><strong>{{ visite.agentVisite }}</strong></dd>
                    <dt class="col-sm-5">Prénom</dt><dd class="col-sm-7">{{ visite.prenomVisite }}</dd>
                    <dt class="col-sm-5">Pôle / Service</dt><dd class="col-sm-7">{{ visite.poleServiceVisite }}</dd>
                    <dt class="col-sm-5">Emploi</dt><dd class="col-sm-7">{{ visite.emploiVisite }}</dd>
                    <dt class="col-sm-5">Dates réalisées</dt><dd class="col-sm-7">
                        {% set realisees = visite.dates|filter(d => d.type == 'realisee' and not d.annulee)|sort((a, b) => (a.date|slice(6,4)~a.date|slice(3,2)~a.date|slice(0,2)) <=> (b.date|slice(6,4)~b.date|slice(3,2)~b.date|slice(0,2))) %}
                        {% if realisees|length %}{% for d in realisees %}<span class="badge bg-primary me-1">{{ d.date }}{% if d.categorie %} · {{ d.categorie }}{% endif %}</span>{% endfor %}{% else %}-{% endif %}
                        {% set annulees = visite.dates|filter(d => d.annulee) %}
                        {% if annulees|length %}
                            <div class="mt-1">{% for d in annulees %}<span class="badge bg-secondary text-decoration-line-through me-1" title="{{ d.motifAnnulation }}">{{ d.date }}{% if d.categorie %} · {{ d.categorie }}{% endif %}</span>{% if d.motifAnnulation %}<small class="text-muted fst-italic me-2">{{ d.motifAnnulation }}</small>{% endif %}{% endfor %}</div>
                        {% endif %}
                    </dd>
                    <dt class="col-sm-5">Prochaines visites</dt><dd class="col-sm-7">
                        {% set prochaines = visite.dates|filter(d => d.type == 'prochaine' and not d.annulee) %}
                        {% if prochaines|length %}
                            {% for d in prochaines %}
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge bg-success">{{ d.date }}{% if d.categorie %} · {{ d.categorie }}{% endif %}{% if d.heure %} {{ d.heure }}{% endif %}</span>
                                <a href="{{ path('app_visite_convocation', {id: visite.id, dateId: d.id}) }}" class="btn btn-warning btn-sm py-0 px-2" title="Générer la convocation" target="_blank"><i class="bi bi-envelope me-1"></i>Convocation</a>
                            </div>
                            {% endfor %}
                        {% else %}-{% endif %}
                    </dd>
                    <dt class="col-sm-5">RQTH</dt><dd class="col-sm-7">
                        {% if visite.rqthVisite == 'oui' %}<span class="badge bg-warning text-dark">Oui</span>{% else %}<span class="badge bg-light text-dark">Non</span>{% endif %}
                    </dd>
                    <dt class="col-sm-5">Saisi par</dt><dd class="col-sm-7">{{ visite.userVisite }}</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-secondary text-white">Restrictions / Recommandations</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Restrictions</dt><dd class="col-sm-8">{{ visite.restrictionVisite|nl2br }}</dd>
                    <dt class="col-sm-4">Recommandations</dt><dd class="col-sm-8">{{ visite.recommandationVisite|nl2br }}</dd>
                    <dt class="col-sm-4">Limitations</dt><dd class="col-sm-8">{{ visite.limitationVisite|nl2br }}</dd>
                    <dt class="col-sm-4">Observation</dt><dd class="col-sm-8">{{ visite.observation }}</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">Conditions de travail</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-7">Travail penché</dt><dd class="col-sm-5">{{ visite.travailPencheVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Debout prolongé</dt><dd class="col-sm-5">{{ visite.deboutVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Conduite</dt><dd class="col-sm-5">{{ visite.conduiteVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Ecran</dt><dd class="col-sm-5">{{ visite.utilisationVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Travail en hauteur</dt><dd class="col-sm-5">{{ visite.travailHautVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Travail isolé</dt><dd class="col-sm-5">{{ visite.travailIsoVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Travail en position basse</dt><dd class="col-sm-5">{{ visite.travailBasVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Effort / Force</dt><dd class="col-sm-5">{{ visite.effortVisite ? 'Oui' : 'Non' }}</dd>
                    <dt class="col-sm-7">Port de charges</dt><dd class="col-sm-5">{{ visite.port }}</dd>
                    <dt class="col-sm-7">EPI</dt><dd class="col-sm-5">{{ visite.epi }} {% if visite.epiDetail %}<br><small class="text-muted">{{ visite.epiDetail }}</small>{% endif %}</dd>
                </dl>
            </div>
        </div>
    </div>
    {% if visite.tempsPartielVisite == 'oui' %}
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">Temps partiel thérapeutique</div>
            <div class="card-body">
                <dl class="row mb-0">
                    {% if visite.tpt1Du %}<dt class="col-sm-5">Période 1</dt><dd class="col-sm-7">du {{ visite.tpt1Du }} au {{ visite.tpt1Au }}</dd>{% endif %}
                    {% if visite.tpt2Du %}<dt class="col-sm-5">Période 2</dt><dd class="col-sm-7">du {{ visite.tpt2Du }} au {{ visite.tpt2Au }}</dd>{% endif %}
                    {% if visite.tpt3Du %}<dt class="col-sm-5">Période 3</dt><dd class="col-sm-7">du {{ visite.tpt3Du }} au {{ visite.tpt3Au }}</dd>{% endif %}
                    {% if visite.tpt4Du %}<dt class="col-sm-5">Période 4</dt><dd class="col-sm-7">du {{ visite.tpt4Du }} au {{ visite.tpt4Au }}</dd>{% endif %}
                </dl>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-paperclip"></i> Pièces jointes</span>
                <button class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#formPj">
                    <i class="bi bi-upload"></i> Ajouter un fichier
                </button>
            </div>
            <div class="collapse" id="formPj">
                <div class="card-body border-bottom">
                    <form method="post" action="{{ path('app_visite_pj_upload', {id: visite.id}) }}" enctype="multipart/form-data" class="d-flex gap-2 align-items-end flex-wrap">
                        <div>
                            <label class="form-label mb-1 small">Fichier</label>
                            <input type="file" name="fichier" class="form-control form-control-sm" required>
                        </div>
                        <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-lg"></i> Enregistrer</button>
                    </form>
                </div>
            </div>
            <div class="card-body p-0">
                {% if piecesJointes is empty %}
                    <p class="text-muted text-center py-4 mb-0"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucune pièce jointe.</p>
                {% else %}
                <table class="table table-hover mb-0">
                    <thead><tr><th>Fichier</th><th>Taille</th><th>Ajouté le</th><th></th></tr></thead>
                    <tbody>
                    {% for pj in piecesJointes %}
                    <tr>
                        <td>
                            {% set ext = pj.extension %}
                            {% if ext in ['pdf'] %}<i class="bi bi-file-earmark-pdf text-danger me-1"></i>
                            {% elseif ext in ['doc','docx'] %}<i class="bi bi-file-earmark-word text-primary me-1"></i>
                            {% elseif ext in ['xls','xlsx'] %}<i class="bi bi-file-earmark-excel text-success me-1"></i>
                            {% elseif ext in ['jpg','jpeg','png','gif'] %}<i class="bi bi-file-earmark-image text-info me-1"></i>
                            {% else %}<i class="bi bi-file-earmark text-muted me-1"></i>{% endif %}
                            {{ pj.nom }}
                        </td>
                        <td class="text-muted small">{{ pj.taille ? (pj.taille / 1024)|round ~ ' Ko' : '—' }}</td>
                        <td class="text-muted small">{{ pj.dateAjout|date('d/m/Y') }}</td>
                        <td class="text-end text-nowrap">
                            {% if pj.extension in ['pdf','png','jpg','jpeg','gif','webp','svg','txt'] %}
                            <a href="{{ path('app_visite_pj_view', {id: visite.id, pjId: pj.id}) }}" class="btn btn-sm btn-outline-info" title="Visualiser" target="_blank"><i class="bi bi-eye"></i></a>
                            {% endif %}
                            <a href="{{ path('app_visite_pj_download', {id: visite.id, pjId: pj.id}) }}" class="btn btn-sm btn-outline-primary" title="Télécharger"><i class="bi bi-download"></i></a>
                            <form method="post" action="{{ path('app_visite_pj_delete', {id: visite.id, pjId: pj.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce fichier ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-pj-' ~ pj.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
