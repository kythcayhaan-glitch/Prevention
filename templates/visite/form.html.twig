{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-heart"></i> {{ title }}</h2>
    <a href="{{ path('app_visite_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

{{ form_start(form, {attr: {class: 'needs-validation'}}) }}
<div class="row g-3">
    <div class="col-md-12">

        <div class="card mb-3">
            <div class="card-header bg-primary text-white">Informations générales</div>
            <div class="card-body row g-3">
                <div class="col-md-2">{{ form_row(form.genre) }}</div>
                <div class="col-md-3">{{ form_row(form.agentVisite, {attr: {class: 'form-control', style: 'text-transform:uppercase'}}) }}</div>
                <div class="col-md-3">{{ form_row(form.prenomVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-3">{{ form_row(form.poleServiceVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.emploiVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.type, {attr: {class: 'form-select'}}) }}</div>
            </div>
        </div>

        {# ── Section dates ── #}
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-calendar-check"></i> Dates de visite</span>
                <button type="button" id="btn-add-date" class="btn btn-light btn-sm">
                    <i class="bi bi-plus-lg"></i> Ajouter une date
                </button>
            </div>
            <div class="card-body p-3">
                <div id="dates-collection"
                     data-prototype="{{ form_widget(form.dates.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.dates|length }}">

                    {% for dateForm in form.dates %}
                        {% set dateEntity = dateForm.vars.data %}
                        <div class="date-row d-flex align-items-center gap-2 mb-2 flex-wrap">
                            <div style="width:150px">
                                {{ form_widget(dateForm.date) }}
                            </div>
                            <div style="width:140px">
                                {{ form_widget(dateForm.type) }}
                            </div>
                            <div style="width:300px">
                                {{ form_widget(dateForm.categorie) }}
                            </div>
                            <div class="conv-fields d-flex gap-2" style="display:{% if dateEntity.type == 'prochaine' and dateEntity.categorie == 'ESTI' %}flex{% else %}none{% endif %}!important">
                                <div>{{ form_widget(dateForm.heure) }}</div>
                            </div>
                            <a href="#" class="btn btn-success btn-sm btn-fiche" style="display:none"><i class="bi bi-file-medical me-1"></i>Fiche de suivi des visites</a>
                            {% if dateEntity.id and dateEntity.type == 'prochaine' %}
                            <a href="{{ path('app_visite_convocation', {id: visite.id, dateId: dateEntity.id}) }}"
                               class="btn btn-warning btn-sm btn-convocation"
                               title="Générer la convocation"><i class="bi bi-envelope me-1"></i>Convocation</a>
                            {% else %}
                            <a href="#" class="btn btn-warning btn-sm btn-convocation" style="display:none"
                               title="Générer la convocation"><i class="bi bi-envelope me-1"></i>Convocation</a>
                            {% endif %}
                            <button type="button" class="btn btn-outline-danger btn-sm btn-remove-date" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0" id="no-dates-msg">Aucune date enregistrée. Cliquez sur « Ajouter une date ».</p>
                    {% endfor %}
                </div>
            </div>
        </div>


    </div>
</div>

<div class="mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_visite_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>
{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
<script>
(function () {
    const container = document.getElementById('dates-collection');
    const btnAdd = document.getElementById('btn-add-date');
    const noMsg = document.getElementById('no-dates-msg');

    const visiteId = {{ visite.id ?? 'null' }};
    const fichePath = visiteId ? '/visite/' + visiteId + '/fiche-suivi' : null;

    function buildRow(html) {
        const div = document.createElement('div');
        div.className = 'date-row d-flex align-items-center gap-2 mb-2 flex-wrap';
        div.innerHTML =
            '<div style="width:150px">' + extractWidget(html, 'date') + '</div>' +
            '<div style="width:140px">' + extractWidget(html, 'type') + '</div>' +
            '<div style="width:300px">' + extractWidget(html, 'categorie') + '</div>' +
            '<div class="conv-fields d-flex gap-2" style="display:none">' +
                '<div>' + extractWidget(html, 'heure') + '</div>' +
            '</div>' +
            '<a href="#" class="btn btn-success btn-sm btn-fiche" style="display:none"><i class="bi bi-file-medical me-1"></i>Fiche de suivi des visites</a>' +
            '<a href="#" class="btn btn-warning btn-sm btn-convocation" style="display:none" title="Générer la convocation"><i class="bi bi-envelope me-1"></i>Convocation</a>' +
            '<button type="button" class="btn btn-outline-danger btn-sm btn-remove-date" title="Supprimer"><i class="bi bi-trash"></i></button>';
        return div;
    }

    function extractWidget(html, field) {
        const tmp = document.createElement('div');
        tmp.innerHTML = html;
        // find the input/select whose name ends with [field]
        const el = tmp.querySelector('[name*="[' + field + ']"]');
        return el ? el.outerHTML : '';
    }

    function attachRemove(row) {
        row.querySelector('.btn-remove-date').addEventListener('click', function () {
            row.remove();
            if (!container.querySelector('.date-row')) {
                if (noMsg) noMsg.style.display = '';
            }
        });
    }

    function attachTypeWatch(row) {
        const typeSelect = row.querySelector('select[name*="[type]"]');
        const catSelect = row.querySelector('select[name*="[categorie]"]');
        const ficheBtn = row.querySelector('.btn-fiche');
        const convBtn = row.querySelector('.btn-convocation');
        const convFields = row.querySelector('.conv-fields');
        if (!typeSelect) return;

        const update = () => {
            const isProchaine = typeSelect.value === 'prochaine';
            const isEsti = catSelect && catSelect.value === 'ESTI';

            if (ficheBtn) {
                if (typeSelect.value === 'realisee' && fichePath) {
                    ficheBtn.href = fichePath;
                    ficheBtn.style.display = '';
                } else {
                    ficheBtn.style.display = 'none';
                }
            }
            if (convBtn) convBtn.style.display = isProchaine ? '' : 'none';
            if (convFields) convFields.style.display = (isProchaine && isEsti) ? 'flex' : 'none';
        };

        typeSelect.addEventListener('change', update);
        if (catSelect) catSelect.addEventListener('change', update);
        update();
    }

    // Autosave + ouverture PDF pour les boutons convocation
    const autosaveUrl = '{{ path('app_visite_autosave', {id: visite.id ?? 0}) }}';
    const mainForm = document.querySelector('form');

    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-convocation[href]:not([href="#"])');
        if (!btn) return;
        e.preventDefault();
        const pdfUrl = btn.getAttribute('href');
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        btn.classList.add('disabled');

        const data = new FormData(mainForm);
        fetch(autosaveUrl, { method: 'POST', body: data })
            .finally(() => {
                window.open(pdfUrl, '_blank');
                btn.innerHTML = '<i class="bi bi-envelope me-1"></i>Convocation';
                btn.classList.remove('disabled');
            });
    });

    // attach handlers to existing rows
    container.querySelectorAll('.date-row').forEach(row => { attachRemove(row); attachTypeWatch(row); });

    btnAdd.addEventListener('click', function () {
        if (noMsg) noMsg.style.display = 'none';

        let index = parseInt(container.dataset.index);
        const proto = container.dataset.prototype.replace(/__name__/g, index);
        container.dataset.index = index + 1;

        const row = buildRow(proto);
        container.appendChild(row);
        attachRemove(row);
        attachTypeWatch(row);

        // Pré-sélectionner "Prévue" par défaut
        const typeSelect = row.querySelector('select[name*="[type]"]');
        if (typeSelect) typeSelect.value = 'prochaine';

        // initialize date pickers on new row
        initDatePickers(row);
        row.querySelector('input').focus();
    });
})();
</script>
{% endblock %}
