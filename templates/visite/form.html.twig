{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-heart"></i> {{ title }}</h2>
    <a href="{{ path('app_visite_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

{{ form_start(form, {attr: {class: 'needs-validation'}}) }}
<div class="row g-3">
    <div class="col-md-12">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">Informations générales</div>
            <div class="card-body row g-3">
                <div class="col-md-4">{{ form_row(form.agentVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.poleServiceVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.emploiVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.dateVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.prochaineDateVisite, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.type, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.rqthVisite, {attr: {class: 'form-select'}}) }}</div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">Restrictions / Recommandations</div>
            <div class="card-body row g-3">
                <div class="col-md-4">{{ form_row(form.restrictionVisite, {attr: {class: 'form-control', rows: 3}}) }}</div>
                <div class="col-md-4">{{ form_row(form.recommandationVisite, {attr: {class: 'form-control', rows: 3}}) }}</div>
                <div class="col-md-4">{{ form_row(form.limitationVisite, {attr: {class: 'form-control', rows: 3}}) }}</div>
                <div class="col-12">{{ form_row(form.observation, {attr: {class: 'form-control', rows: 2}}) }}</div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-info text-white">Conditions de travail</div>
            <div class="card-body row g-3">
                <div class="col-md-2">{{ form_row(form.travailPencheVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.deboutVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.conduiteVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.utilisationVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.travailHautVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.travailIsoVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.travailBasVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.effortVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.port, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.epi, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-4">{{ form_row(form.epiDetail, {attr: {class: 'form-control', rows: 2}}) }}</div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-warning text-dark">Temps partiel thérapeutique</div>
            <div class="card-body row g-3">
                <div class="col-md-2">{{ form_row(form.tempsPartielVisite, {attr: {class: 'form-select'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt1Du, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt1Au, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt2Du, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt2Au, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt3Du, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt3Au, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt4Du, {attr: {class: 'form-control'}}) }}</div>
                <div class="col-md-2">{{ form_row(form.tpt4Au, {attr: {class: 'form-control'}}) }}</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_visite_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>
{{ form_end(form) }}
{% endblock %}
