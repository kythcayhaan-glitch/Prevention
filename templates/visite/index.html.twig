{% extends 'base.html.twig' %}
{% block title %}Visites de prévention{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clipboard-heart"></i> Visites de prévention</h2>
    <a href="{{ path('app_visite_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nouvelle visite</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="px-3 pt-3 pb-1">
            <input type="text" id="searchInput" class="form-control table-search" placeholder="&#xF52A;  Rechercher (agent, service...)">
        </div>
        <div class="px-3 pb-2 d-flex flex-wrap gap-1 align-items-center">
            <small class="text-muted me-1">Année :</small>
            <button class="btn btn-sm btn-primary year-btn active" data-year="">Toutes</button>
            {% set allYears = [] %}
            {% for visite in visites %}
                {% for d in visite.dates %}
                    {% set y = d.date|slice(-4) %}
                    {% if y not in allYears %}{% set allYears = allYears|merge([y]) %}{% endif %}
                {% endfor %}
            {% endfor %}
            {% for y in allYears|sort %}
                <button class="btn btn-sm btn-outline-primary year-btn" data-year="{{ y }}">{{ y }}</button>
            {% endfor %}
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="mainTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th id="th-nom" style="cursor:pointer;user-select:none">Nom <span id="sort-icon">↕</span></th>
                        <th>Prénom</th>
                        <th>Pôle / Service</th>
                        <th>Emploi</th>
                        <th>Dates réalisées</th>
                        <th>Prochaines visites</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for visite in visites %}
                    {% set rowYears = [] %}
                    {% for d in visite.dates %}
                        {% set y = d.date|slice(-4) %}
                        {% if y not in rowYears %}{% set rowYears = rowYears|merge([y]) %}{% endif %}
                    {% endfor %}
                    <tr data-href="{{ path('app_visite_show', {id: visite.id}) }}" data-years="{{ rowYears|join(',') }}">
                        <td>{{ visite.id }}</td>
                        <td><strong>{{ visite.agentVisite }}</strong></td>
                        <td>{{ visite.prenomVisite }}</td>
                        <td>{{ visite.poleServiceVisite }}</td>
                        <td>{{ visite.emploiVisite }}</td>
                        <td>
                            {% set realisees = visite.dates|filter(d => d.type == 'realisee' and not d.annulee)|sort((a, b) => (a.date|slice(6,4)~a.date|slice(3,2)~a.date|slice(0,2)) <=> (b.date|slice(6,4)~b.date|slice(3,2)~b.date|slice(0,2))) %}
                            {% set annulees = visite.dates|filter(d => d.annulee) %}
                            {% if realisees|length %}
                                {% for d in realisees %}<span class="badge bg-primary me-1">{{ d.date }}</span>{% endfor %}
                            {% endif %}
                            {% for d in annulees %}<span class="badge bg-secondary text-decoration-line-through me-1" title="Annulée{% if d.motifAnnulation %} : {{ d.motifAnnulation }}{% endif %}">{{ d.date }}</span>{% endfor %}
                            {% if not realisees|length and not annulees|length %}-{% endif %}
                        </td>
                        <td>
                            {% set prochaines = visite.dates|filter(d => d.type == 'prochaine' and not d.annulee) %}
                            {% if prochaines|length %}
                                {% for d in prochaines %}<span class="badge bg-success me-1">{{ d.date }}{% if d.categorie %} · {{ d.categorie }}{% endif %}</span>{% endfor %}
                            {% else %}-{% endif %}
                        </td>
                        <td class="text-nowrap" onclick="event.stopPropagation()">
                            <a href="{{ path('app_visite_show', {id: visite.id}) }}" class="btn btn-sm btn-outline-primary" title="Consulter"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('app_visite_edit', {id: visite.id}) }}" class="btn btn-sm btn-outline-secondary" title="Planification visite médicale"><i class="bi bi-pencil"></i></a>
                            <a href="{{ path('app_visite_fiche_suivi', {id: visite.id}) }}" class="btn btn-sm btn-outline-success" title="Fiche de suivi"><i class="bi bi-file-medical"></i></a>
                            {% if pj_counts[visite.id] is defined %}
                                <a href="{{ path('app_visite_show', {id: visite.id}) }}" class="btn btn-sm btn-outline-warning" title="{{ pj_counts[visite.id] }} pièce(s) jointe(s)"><i class="bi bi-paperclip"></i></a>
                            {% endif %}
                            <form method="post" action="{{ path('app_visite_delete', {id: visite.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer la suppression ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ visite.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucune visite enregistrée.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
{% block javascripts %}
<script>
let activeYear = '2026';

function applyFilters() {
    const filter = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#mainTable tbody tr').forEach(row => {
        const matchSearch = !filter || row.textContent.toLowerCase().includes(filter);
        const years = row.dataset.years ? row.dataset.years.split(',') : [];
        const matchYear = !activeYear || years.includes(activeYear);
        row.style.display = (matchSearch && matchYear) ? '' : 'none';
    });
}

document.getElementById('searchInput').addEventListener('keyup', applyFilters);

document.querySelectorAll('.year-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.year-btn').forEach(b => b.classList.remove('active', 'btn-primary'));
        document.querySelectorAll('.year-btn').forEach(b => b.classList.add('btn-outline-primary'));
        this.classList.remove('btn-outline-primary');
        this.classList.add('active', 'btn-primary');
        activeYear = this.dataset.year;
        applyFilters();
    });
});

let sortAsc = null;
function sortByNom(asc) {
    const tbody = document.querySelector('#mainTable tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
        const A = a.cells[1] ? a.cells[1].textContent.trim() : '';
        const B = b.cells[1] ? b.cells[1].textContent.trim() : '';
        return asc ? A.localeCompare(B, 'fr') : B.localeCompare(A, 'fr');
    });
    rows.forEach(r => tbody.appendChild(r));
    document.getElementById('sort-icon').textContent = asc ? '↑' : '↓';
}
document.getElementById('th-nom').addEventListener('click', function() {
    sortAsc = sortAsc === true ? false : true;
    sortByNom(sortAsc);
});
sortAsc = true;
sortByNom(true);

// Activer le bouton année par défaut
document.querySelectorAll('.year-btn').forEach(btn => {
    if (btn.dataset.year === activeYear) {
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('active', 'btn-primary');
    } else {
        btn.classList.remove('active', 'btn-primary');
        btn.classList.add('btn-outline-primary');
    }
});
applyFilters();
</script>
{% endblock %}
