{% extends 'base.html.twig' %}
{% block title %}Fiche de suivi — {{ visite.agentVisite }} {{ visite.prenomVisite }}{% endblock %}

{% block stylesheets %}
<style>
    /* ── Écran ─────────────────────────────────────────────── */
    .section-title { background: #0d6efd; color: white; padding: .35rem .75rem; border-radius: 4px; font-size: .85rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .75rem; }
    .section-title.bg-secondary { background: #6c757d !important; }
    .section-title.bg-info    { background: #0dcaf0 !important; color: #000 !important; }
    .section-title.bg-warning { background: #ffc107 !important; color: #000 !important; }
    .agent-banner { background: #f8f9fa; border-left: 4px solid #0d6efd; padding: .75rem 1rem; border-radius: 4px; }
    .btn-check:checked + .btn-outline-primary {
        background-color: #0d6efd !important; border-color: #0d6efd !important;
        color: #fff !important; font-weight: 700 !important;
        box-shadow: 0 0 0 4px rgba(13,110,253,.4) !important;
    }
    .print-only { display: none !important; }

    /* ── Impression ─────────────────────────────────────────── */
    @media print {
        @page { size: A4 portrait; margin: 1.2cm 1.5cm; }

        /* Masquer tout le contenu écran */
        nav.navbar, .sidebar, footer, form,
        .agent-banner, .no-print { display: none !important; }

        /* Révéler la section impression */
        .print-only { display: block !important; }

        /* Pleine largeur */
        .col-md-10 { width: 100% !important; max-width: 100% !important; flex: 0 0 100% !important; padding: 0 !important; }
        main.main-content { padding: 0 !important; margin: 0 !important; }

        body { font-size: 9.5pt; font-family: Arial, Helvetica, sans-serif; background: #fff !important; color: #000; }

        /* En-tête */
        .pd-header { display: flex !important; justify-content: space-between; align-items: center; border-bottom: 2pt solid #222; padding-bottom: 8pt; margin-bottom: 10pt; }
        .pd-header img { height: 36pt; }
        .pd-header-title { font-size: 15pt; font-weight: bold; text-transform: uppercase; letter-spacing: .08em; text-align: center; }
        .pd-header-sub { font-size: 8pt; color: #555; text-align: center; margin-top: 2pt; }
        .pd-header-date { font-size: 8pt; color: #444; text-align: right; line-height: 1.5; }

        /* Bloc agent */
        .pd-agent { border: 1.5pt solid #222; border-left: 5pt solid #222; padding: 6pt 10pt; margin-bottom: 8pt; font-size: 9.5pt; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pd-agent-name { font-size: 12pt; font-weight: bold; margin-bottom: 3pt; }
        .pd-agent-info { font-size: 8.5pt; color: #333; }
        .pd-agent-dates { margin-top: 4pt; font-size: 8.5pt; }
        .pd-badge { display: inline-block; background: #222 !important; color: #fff !important; font-size: 7.5pt; padding: 1pt 4pt; margin-right: 3pt; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

        /* Titres de section */
        .pd-title { font-size: 8pt; font-weight: bold; text-transform: uppercase; letter-spacing: .05em;
            padding: 3pt 7pt; margin: 7pt 0 4pt; color: #fff !important;
            -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pd-title-dark    { background: #343a40 !important; }
        .pd-title-gray    { background: #6c757d !important; }
        .pd-title-info    { background: #0891b2 !important; }
        .pd-title-warning { background: #b45309 !important; }
        .pd-title-dark2   { background: #1e293b !important; }

        /* Cellules de contenu */
        .pd-cell { border: 0.5pt solid #ccc; padding: 4pt 6pt; font-size: 9pt; vertical-align: top; }
        .pd-cell-label { font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #555; margin-bottom: 2pt; }

        /* Tableaux */
        .pd-table { border-collapse: collapse; width: 100%; font-size: 8.5pt; }
        .pd-table th { background: #333 !important; color: #fff !important; padding: 3pt 6pt; text-align: left; font-size: 8pt; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .pd-table td { padding: 3pt 6pt; border-bottom: 0.5pt solid #e0e0e0; }
        .pd-table tr.prochaine td { background: #f0fdf4 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

        /* Signatures */
        .pd-signatures { display: flex !important; justify-content: flex-end; gap: 50pt; margin-top: 28pt; }
        .pd-sig-box { text-align: center; font-size: 8pt; }
        .pd-sig-line { border-bottom: 0.75pt solid #000; width: 110pt; margin: 28pt auto 3pt; }
    }
</style>
{% endblock %}

{% block body %}

{# ── Boutons écran ─────────────────────────────────────────── #}
<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <h2><i class="bi bi-file-medical"></i> Fiche de suivi</h2>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-primary btn-sm"><i class="bi bi-printer"></i> Imprimer</button>
        <a href="{{ path('app_visite_show', {id: visite.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Retour</a>
    </div>
</div>

{# ── SECTION IMPRESSION UNIQUEMENT ─────────────────────────── #}
<div class="print-only">

    {# En-tête document #}
    <div class="pd-header">
        <img src="/images/logo_mairie.png" alt="Mairie d'Outreau">
        <div>
            <div class="pd-header-title">Fiche de suivi</div>
            <div class="pd-header-sub">Service Prévention &amp; Médecine du travail</div>
        </div>
        <div class="pd-header-date">
            Imprimé le {{ "now"|date("d/m/Y") }}<br>
            Réf. dossier : #{{ visite.id }}
        </div>
    </div>

    {# Bloc agent #}
    <div class="pd-agent">
        <div class="pd-agent-name">{{ visite.agentVisite }} {{ visite.prenomVisite }}</div>
        <div class="pd-agent-info">
            {% if visite.poleServiceVisite %}Service : <strong>{{ visite.poleServiceVisite }}</strong>{% endif %}
            {% if visite.emploiVisite %}&nbsp;&nbsp;|&nbsp;&nbsp;Emploi : <strong>{{ visite.emploiVisite }}</strong>{% endif %}
        </div>
        {% if realisees|length > 0 %}
        <div class="pd-agent-dates">
            Visite(s) réalisée(s) :
            {% for d in realisees %}
                <span class="pd-badge">{{ d.date }}{% if d.categorie %} · {{ d.categorie }}{% endif %}</span>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    {# Historique des visites #}
    <div class="pd-title pd-title-dark">Historique des visites</div>
    <table class="pd-table">
        <thead>
            <tr><th>Date</th><th>Type</th><th>Catégorie</th><th>Motif annulation</th></tr>
        </thead>
        <tbody>
        {% set toutes = visite.dates|sort((a, b) => a.date <=> b.date) %}
        {% for d in toutes %}
            <tr class="{{ d.annulee ? '' : (d.type == 'prochaine' ? 'prochaine' : '') }}"
                style="{{ d.annulee ? 'opacity:.55' : '' }}">
                <td style="{{ d.annulee ? 'text-decoration:line-through' : '' }}">{{ d.date }}</td>
                <td>{{ d.annulee ? 'Annulée' : (d.type == 'prochaine' ? 'Prévue' : 'Réalisée') }}</td>
                <td>{{ d.categorie ?: '—' }}</td>
                <td style="font-style:italic;color:#666">{{ d.motifAnnulation ?: '' }}</td>
            </tr>
        {% else %}
            <tr><td colspan="4" style="color:#777;font-style:italic">Aucune date enregistrée.</td></tr>
        {% endfor %}
        </tbody>
    </table>

    {# Restrictions / Recommandations / Limitations #}
    {% set hasPresc = visite.restrictionVisite or visite.recommandationVisite or visite.limitationVisite %}
    {% if hasPresc %}
    <div class="pd-title pd-title-gray">Restrictions / Recommandations / Limitations</div>
    <table style="width:100%;border-collapse:collapse;table-layout:fixed">
        <tr style="vertical-align:top">
            {% if visite.restrictionVisite %}
            <td class="pd-cell">
                <div class="pd-cell-label">Restrictions</div>
                {{ visite.restrictionVisite|nl2br }}
            </td>
            {% endif %}
            {% if visite.recommandationVisite %}
            <td class="pd-cell">
                <div class="pd-cell-label">Recommandations</div>
                {{ visite.recommandationVisite|nl2br }}
            </td>
            {% endif %}
            {% if visite.limitationVisite %}
            <td class="pd-cell">
                <div class="pd-cell-label">Limitations</div>
                {{ visite.limitationVisite|nl2br }}
            </td>
            {% endif %}
        </tr>
    </table>
    {% endif %}

    {# Observations #}
    {% if visite.observation %}
    <div class="pd-title pd-title-gray" style="margin-top:6pt">Observations</div>
    <div class="pd-cell">{{ visite.observation|nl2br }}</div>
    {% endif %}

    {# EPI #}
    {% if visite.epi %}
    <div class="pd-title pd-title-dark2" style="margin-top:6pt">EPI</div>
    <div class="pd-cell">
        <strong>{{ visite.epi|capitalize }}</strong>
        {% if visite.epiDetail %}&nbsp;— {{ visite.epiDetail }}{% endif %}
    </div>
    {% endif %}

    {# Conditions de travail #}
    {% set condLabels = {
        'travailPencheVisite': 'Travail penché',
        'deboutVisite':        'Debout prolongé',
        'conduiteVisite':      'Conduite',
        'utilisationVisite':   'Écran',
        'travailHautVisite':   'Travail en hauteur',
        'travailIsoVisite':    'Travail isolé',
        'travailBasVisite':    'Position basse',
        'effortVisite':        'Effort / Force'
    } %}
    {% set activeCond = [] %}
    {% for field, label in condLabels %}
        {% if attribute(visite, field) %}
            {% set activeCond = activeCond|merge([label]) %}
        {% endif %}
    {% endfor %}
    {% if activeCond|length > 0 or visite.port %}
    <div class="pd-title pd-title-info" style="margin-top:6pt">Conditions de travail</div>
    <div class="pd-cell">
        {% if activeCond|length > 0 %}
        <div style="margin-bottom:{% if visite.port %}4pt{% endif %}">
            {% for label in activeCond %}
                <span style="display:inline-block;margin-right:12pt;font-size:9pt">✓ {{ label }}</span>
            {% endfor %}
        </div>
        {% endif %}
        {% if visite.port %}
        <div><strong>Port de charges :</strong> {{ visite.port }}</div>
        {% endif %}
    </div>
    {% endif %}

    {# Temps partiel thérapeutique #}
    {% if visite.tempsPartielVisite %}
    <div class="pd-title pd-title-warning" style="margin-top:6pt">Temps partiel thérapeutique</div>
    <div class="pd-cell">
        <div style="margin-bottom:3pt"><strong>{{ visite.tempsPartielVisite|capitalize }}</strong></div>
        {% set tpts = [
            {du: visite.tpt1Du, au: visite.tpt1Au, n: 1},
            {du: visite.tpt2Du, au: visite.tpt2Au, n: 2},
            {du: visite.tpt3Du, au: visite.tpt3Au, n: 3},
            {du: visite.tpt4Du, au: visite.tpt4Au, n: 4}
        ] %}
        {% for tpt in tpts %}
            {% if tpt.du or tpt.au %}
            <div style="font-size:8.5pt">Période {{ tpt.n }} : du <strong>{{ tpt.du ?: '—' }}</strong> au <strong>{{ tpt.au ?: '—' }}</strong></div>
            {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    {# Signatures #}
    <div class="pd-signatures">
        <div class="pd-sig-box">
            <div class="pd-sig-line"></div>
            Le médecin de prévention
        </div>
        <div class="pd-sig-box">
            <div class="pd-sig-line"></div>
            L'infirmière de prévention
        </div>
    </div>

</div>
{# ── Fin section impression ────────────────────────────────── #}

{# Bandeau agent + dates — écran seulement #}
<div class="agent-banner mb-4 d-flex flex-wrap gap-4 align-items-center">
    <div>
        <div class="text-muted small">Agent</div>
        <strong class="fs-5">{{ visite.agentVisite }} {{ visite.prenomVisite }}</strong>
    </div>
    <div>
        <div class="text-muted small">Pôle / Service</div>
        <span>{{ visite.poleServiceVisite ?: '—' }}</span>
    </div>
    <div>
        <div class="text-muted small">Emploi</div>
        <span>{{ visite.emploiVisite ?: '—' }}</span>
    </div>
    <div>
        <div class="text-muted small">Visite(s) réalisée(s)</div>
        {% for d in realisees %}
            <span class="badge bg-primary me-1">{{ d.date }}{% if d.categorie %} · {{ d.categorie }}{% endif %}</span>
        {% else %}
            <span class="text-muted">—</span>
        {% endfor %}
    </div>
    <div>
        <div class="text-muted small">Réf.</div>
        <span class="text-muted">#{{ visite.id }}</span>
    </div>
</div>

{{ form_start(form) }}

<div class="row g-3">

    {# Historique des visites #}
    <div class="col-12">
        <div class="section-title" style="background:#343a40"><i class="bi bi-calendar3"></i> Historique des visites</div>
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-dark">
                <tr><th>Date</th><th>Type</th><th>Catégorie</th><th>Motif annulation</th></tr>
            </thead>
            <tbody>
            {% set toutes = visite.dates|sort((a, b) => a.date <=> b.date) %}
            {% for d in toutes %}
                <tr class="{{ d.annulee ? 'table-secondary' : (d.type == 'prochaine' ? 'table-success' : '') }}">
                    <td class="{{ d.annulee ? 'text-decoration-line-through text-muted' : '' }}">{{ d.date }}</td>
                    <td>
                        {% if d.annulee %}
                            <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Annulée</span>
                        {% elseif d.type == 'prochaine' %}
                            <span class="badge bg-success">Prévue</span>
                        {% else %}
                            <span class="badge bg-primary">Réalisée</span>
                        {% endif %}
                    </td>
                    <td>{{ d.categorie ?: '—' }}</td>
                    <td class="text-muted fst-italic small">{{ d.motifAnnulation ?: '' }}</td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-muted text-center">Aucune date enregistrée.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# Prochaine visite #}
    <div class="col-12">
        <div class="section-title" style="background:#198754"><i class="bi bi-calendar-plus"></i> Prochaine visite prévue</div>
        {% if derniere_realisee %}
        <p class="text-muted small mb-2">Dernière visite réalisée le <strong>{{ derniere_realisee.date }}</strong>{% if derniere_realisee.categorie %} ({{ derniere_realisee.categorie }}){% endif %}.</p>
        {% endif %}
        <div class="row g-2 align-items-end">
            <div class="col-md-4 pb-2">
                <label class="form-label text-muted small d-block">A revoir dans :</label>
                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check delai-radio" name="delai_visite" id="delai3"  value="3"  autocomplete="off">
                    <label class="btn btn-outline-primary" for="delai3">3 mois</label>
                    <input type="radio" class="btn-check delai-radio" name="delai_visite" id="delai6"  value="6"  autocomplete="off">
                    <label class="btn btn-outline-primary" for="delai6">6 mois</label>
                    <input type="radio" class="btn-check delai-radio" name="delai_visite" id="delai12" value="12" autocomplete="off">
                    <label class="btn btn-outline-primary" for="delai12">1 an</label>
                </div>
            </div>
            <div class="col-md-3">
                {{ form_row(form.prochaineDate, {attr: {class: 'form-control date-picker prochaine-date-field'}}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.prochaineCategorie, {attr: {class: 'form-select'}}) }}
            </div>
            <div class="col-auto">
                {{ form_row(form.prochaineHeure, {attr: {class: 'form-control', placeholder: 'HH:MM', style: 'width:90px'}}) }}
            </div>
        </div>
    </div>

    {# Prescriptions + EPI #}
    <div class="col-12">
        <div class="row g-3 mb-0">
            <div class="col-md-9">
                <div class="card h-100">
                    <div class="card-header bg-secondary text-white"><i class="bi bi-clipboard2-pulse"></i> Restrictions / Recommandations</div>
                    <div class="card-body row g-2">
                        <div class="col-md-4">{{ form_row(form.restrictionVisite, {attr: {class: 'form-control form-control-sm', rows: 5}}) }}</div>
                        <div class="col-md-4">{{ form_row(form.recommandationVisite, {attr: {class: 'form-control form-control-sm', rows: 5}}) }}</div>
                        <div class="col-md-4">{{ form_row(form.limitationVisite, {attr: {class: 'form-control form-control-sm', rows: 5}}) }}</div>
                        <div class="col-12">{{ form_row(form.observation, {attr: {class: 'form-control form-control-sm', rows: 2}}) }}</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-header bg-dark text-white"><i class="bi bi-shield-check"></i> EPI</div>
                    <div class="card-body row g-2">
                        <div class="col-12">{{ form_row(form.epi, {attr: {class: 'form-select form-select-sm'}}) }}</div>
                        <div class="col-12">{{ form_row(form.epiDetail, {attr: {class: 'form-control form-control-sm', rows: 3}}) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Conditions de travail + TPT #}
    <div class="col-12">
        <div class="row g-3 mb-0">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-info text-white"><i class="bi bi-tools"></i> Conditions de travail</div>
                    <div class="card-body">
                        <div class="row g-2 mb-2">
                            {% for field in ['travailPencheVisite','deboutVisite','conduiteVisite','utilisationVisite','travailHautVisite','travailIsoVisite','travailBasVisite','effortVisite'] %}
                            <div class="col-6">
                                <div class="form-check">
                                    {{ form_widget(form[field]) }}
                                    {{ form_label(form[field], null, {label_attr: {class: 'form-check-label'}}) }}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                        <div class="row g-2">
                            <div class="col-12">{{ form_row(form.port, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-warning text-dark"><i class="bi bi-clock-history"></i> Temps partiel thérapeutique</div>
                    <div class="card-body row g-2">
                        <div class="col-12">{{ form_row(form.tempsPartielVisite, {attr: {class: 'form-select form-select-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt1Du, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt1Au, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt2Du, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt2Au, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt3Du, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt3Au, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt4Du, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                        <div class="col-6">{{ form_row(form.tpt4Au, {attr: {class: 'form-control form-control-sm'}}) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="mt-4">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_visite_show', {id: visite.id}) }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>

{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
<script>
(function () {
    const refDate = '{{ derniere_realisee ? derniere_realisee.date : '' }}';

    function parseDD(str) {
        if (!str) return new Date();
        const p = str.split('/');
        if (p.length !== 3) return new Date();
        return new Date(parseInt(p[2]), parseInt(p[1]) - 1, parseInt(p[0]));
    }

    function formatDD(d) {
        return String(d.getDate()).padStart(2,'0') + '/' +
               String(d.getMonth()+1).padStart(2,'0') + '/' +
               d.getFullYear();
    }

    function applyDelai(mois) {
        const base = parseDD(refDate);
        base.setMonth(base.getMonth() + mois);
        const input = document.querySelector('.prochaine-date-field');
        if (!input) return;
        const fp = input._flatpickr;
        if (fp) fp.setDate(formatDD(base), true, 'd/m/Y');
        else input.value = formatDD(base);
    }

    document.querySelectorAll('.delai-radio').forEach(function (radio) {
        radio.addEventListener('change', function () {
            if (this.checked) applyDelai(parseInt(this.value));
        });
    });

    const dateInput = document.querySelector('.prochaine-date-field');
    if (dateInput) {
        dateInput.addEventListener('input', function (e) {
            if (e.isTrusted) document.querySelectorAll('.delai-radio').forEach(r => r.checked = false);
        });
    }
})();
</script>
{% endblock %}
