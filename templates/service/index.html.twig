{% extends 'base.html.twig' %}
{% block title %}Services{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-diagram-3"></i> Services</h2>
    <a href="{{ path('app_service_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ajouter</a>
</div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0">
<thead><tr><th>#</th><th>Service</th><th>Actions</th></tr></thead>
<tbody>
{% for item in services %}
<tr><td>{{ item.id }}</td><td>{{ item.service }}</td><td>
    <a href="{{ path('app_service_edit', {id: item.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
    <form method="post" action="{{ path('app_service_delete', {id: item.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer ?')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
    </form>
</td></tr>
{% else %}<tr><td colspan="3" class="text-center text-muted py-4">Aucun service.</td></tr>{% endfor %}
</tbody></table></div></div>
{% endblock %}
