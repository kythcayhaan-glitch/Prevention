{% extends 'base.html.twig' %}
{% block title %}Interventions{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> Interventions</h2>
    <a href="{{ path('app_inter_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nouvelle intervention</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="px-3 pt-3 pb-2">
            <input type="text" id="searchInput" class="form-control table-search" placeholder="&#xF52A;  Rechercher (date, type, service...)">
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="mainTable">
                <thead><tr>
                    <th>#</th><th>Date</th><th>Type</th><th>Service</th>
                    <th>Description</th><th>Urgence</th><th>Par</th><th>Actions</th>
                </tr></thead>
                <tbody>
                {% for inter in inters %}
                <tr data-href="{{ path('app_inter_show', {id: inter.id}) }}">
                    <td class="text-muted">{{ inter.id }}</td>
                    <td>{{ inter.date }}</td>
                    <td><span class="badge bg-info text-dark">{{ inter.type }}</span></td>
                    <td>{{ inter.service }}</td>
                    <td class="text-truncate" style="max-width:200px">{{ inter.panneAnnonce }}</td>
                    <td>{% if inter.urgence == 'oui' %}<span class="badge bg-danger">Urgent</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                    <td>{{ inter.par }}</td>
                    <td class="text-nowrap" onclick="event.stopPropagation()">
                        <a href="{{ path('app_inter_show', {id: inter.id}) }}" class="btn btn-sm btn-outline-primary" title="Consulter"><i class="bi bi-eye"></i></a>
                        <a href="{{ path('app_inter_edit', {id: inter.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('app_inter_delete', {id: inter.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer la suppression ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inter.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucune intervention.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
{% block javascripts %}<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    const f = this.value.toLowerCase();
    document.querySelectorAll('#mainTable tbody tr').forEach(r => r.style.display = r.textContent.toLowerCase().includes(f) ? '' : 'none');
});
</script>{% endblock %}
