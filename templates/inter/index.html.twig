{% extends 'base.html.twig' %}
{% block title %}Interventions{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> Interventions</h2>
    <a href="{{ path('app_inter_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nouvelle intervention</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="px-3 pt-3 pb-2">
            <input type="text" id="searchInput" class="form-control table-search" placeholder="&#xF52A;  Rechercher (date, type, service...)">
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="mainTable">
                <thead><tr>
                    <th>#</th>
                    <th class="sortable" data-col="1" data-type="date">Date <i class="bi bi-arrow-down-up sort-icon"></i></th>
                    <th>Service</th>
                    <th class="sortable" data-col="3" data-type="text">Agent <i class="bi bi-arrow-down-up sort-icon"></i></th>
                    <th>Description</th><th>Urgence</th><th>Actions</th>
                </tr></thead>
                <tbody>
                {% for inter in inters %}
                <tr data-href="{{ path('app_inter_show', {id: inter.id}) }}">
                    <td class="text-muted">{{ inter.id }}</td>
                    <td>{{ inter.date }}</td>
                    <td>{{ inter.service }}</td>
                    <td>{{ inter.agentVisite }}</td>
                    <td class="text-truncate" style="max-width:200px">{{ inter.panneAnnonce }}</td>
                    <td>
                        {% if inter.urgence == 'a_traiter' %}<span class="badge bg-danger">A traiter</span>
                        {% elseif inter.urgence == 'en_cours' %}<span class="badge bg-warning text-dark">En cours</span>
                        {% elseif inter.urgence == 'traite' %}<span class="badge bg-success">Traité</span>
                        {% else %}<span class="text-muted">—</span>{% endif %}
                    </td>
                    <td class="text-nowrap" onclick="event.stopPropagation()">
                        <a href="{{ path('app_inter_show', {id: inter.id}) }}" class="btn btn-sm btn-outline-primary" title="Consulter"><i class="bi bi-eye"></i></a>
                        <a href="{{ path('app_inter_edit', {id: inter.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('app_inter_delete', {id: inter.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer la suppression ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inter.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucune intervention.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
{% block javascripts %}<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    const f = this.value.toLowerCase();
    document.querySelectorAll('#mainTable tbody tr').forEach(r => r.style.display = r.textContent.toLowerCase().includes(f) ? '' : 'none');
});

(function () {
    let sortCol = null, sortAsc = true;

    function parseDate(str) {
        const p = str.trim().split('/');
        if (p.length === 3) return new Date(p[2], p[1] - 1, p[0]);
        return new Date(str);
    }

    document.querySelectorAll('#mainTable th.sortable').forEach(th => {
        th.style.cursor = 'pointer';
        th.addEventListener('click', function () {
            const col = parseInt(this.dataset.col);
            const type = this.dataset.type;
            sortAsc = (sortCol === col) ? !sortAsc : true;
            sortCol = col;

            document.querySelectorAll('#mainTable th .sort-icon').forEach(i => i.className = 'bi bi-arrow-down-up sort-icon');
            this.querySelector('.sort-icon').className = 'bi bi-arrow-' + (sortAsc ? 'up' : 'down') + ' sort-icon';

            const tbody = document.querySelector('#mainTable tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            rows.sort((a, b) => {
                const va = a.cells[col] ? a.cells[col].textContent.trim() : '';
                const vb = b.cells[col] ? b.cells[col].textContent.trim() : '';
                let cmp;
                if (type === 'date') {
                    cmp = parseDate(va) - parseDate(vb);
                } else {
                    cmp = va.localeCompare(vb, 'fr');
                }
                return sortAsc ? cmp : -cmp;
            });
            rows.forEach(r => tbody.appendChild(r));
        });
    });
})();
</script>{% endblock %}
