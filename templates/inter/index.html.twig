{% extends 'base.html.twig' %}
{% block title %}Interventions{% endblock %}

{% block stylesheets %}
<style>
#mainTable thead th { background: #c0392b; color: #fff; border: none; white-space: nowrap; vertical-align: middle; }
#mainTable thead th.sortable:hover { background: #a93226; }
#mainTable tbody tr { cursor: pointer; transition: background .12s; }
#mainTable tbody tr:hover td { background: #fdf3f2; }
#mainTable td { vertical-align: middle; white-space: nowrap; }
.td-description { max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sort-icon { opacity: .5; font-size: .75rem; }
.table-search-wrap { position: relative; }
.table-search-wrap .bi-search { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #aaa; }
.table-search-wrap input { padding-left: 2.2rem; }
.inter-count { font-size: .85rem; color: #888; }
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-tools"></i> Interventions</h2>
        <small class="inter-count" id="rowCount"></small>
    </div>
    {% if is_granted('ROLE_ADMIN') %}<a href="{{ path('app_inter_new') }}" class="btn btn-danger"><i class="bi bi-plus-lg"></i> Nouvelle intervention</a>{% endif %}
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="px-3 pt-3 pb-2">
            <div class="table-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Rechercher...">
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0" id="mainTable">
                <thead>
                    <tr>
                        <th style="width:50px">#</th>
                        <th class="sortable" data-col="1" data-type="date" style="width:110px">
                            <i class="bi bi-calendar3 me-1"></i>Date <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th style="width:160px">Service</th>
                        <th class="sortable" data-col="3" data-type="text" style="width:180px">
                            <i class="bi bi-person me-1"></i>Agent <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th>Description</th>
                        <th style="width:110px">Urgence</th>
                        <th style="width:105px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for inter in inters %}
                <tr data-href="{{ is_granted('ROLE_ADMIN') ? path('app_inter_edit', {id: inter.id}) : path('app_inter_show', {id: inter.id}) }}">
                    <td class="text-muted small">{{ inter.id }}</td>
                    <td class="fw-semibold">{{ inter.date }}</td>
                    <td>{{ inter.service }}</td>
                    <td>{{ inter.agentVisite }}</td>
                    <td class="td-description text-muted" title="{{ inter.panneAnnonce }}">{{ inter.panneAnnonce }}</td>
                    <td>
                        {% if inter.urgence == 'a_traiter' %}<span class="badge bg-danger">A traiter</span>
                        {% elseif inter.urgence == 'en_cours' %}<span class="badge bg-warning text-dark">En cours</span>
                        {% elseif inter.urgence == 'traite' %}<span class="badge bg-success">Traité</span>
                        {% else %}<span class="text-muted">—</span>{% endif %}
                    </td>
                    <td onclick="event.stopPropagation()">
                        <a href="{{ path('app_inter_show', {id: inter.id}) }}" class="btn btn-sm btn-outline-primary" title="Consulter"><i class="bi bi-eye"></i></a>
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_inter_edit', {id: inter.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('app_inter_delete', {id: inter.id}) }}" class="d-inline" onsubmit="return confirm('Confirmer la suppression ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inter.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>Aucune intervention.
                </td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}<script>
(function () {
    const input = document.getElementById('searchInput');
    const countEl = document.getElementById('rowCount');
    const allRows = () => Array.from(document.querySelectorAll('#mainTable tbody tr[data-href]'));

    function updateCount() {
        const visible = allRows().filter(r => r.style.display !== 'none').length;
        countEl.textContent = visible + ' intervention' + (visible > 1 ? 's' : '');
    }

    input.addEventListener('keyup', function () {
        const f = this.value.toLowerCase();
        allRows().forEach(r => r.style.display = r.textContent.toLowerCase().includes(f) ? '' : 'none');
        updateCount();
    });

    updateCount();

    document.querySelectorAll('#mainTable tbody tr[data-href]').forEach(tr => {
        tr.addEventListener('click', () => window.location = tr.dataset.href);
    });

    let sortCol = null, sortAsc = true;

    function parseDate(str) {
        const p = str.trim().split('/');
        if (p.length === 3) return new Date(p[2], p[1] - 1, p[0]);
        return new Date(str);
    }

    document.querySelectorAll('#mainTable th.sortable').forEach(th => {
        th.style.cursor = 'pointer';
        th.addEventListener('click', function () {
            const col = parseInt(this.dataset.col);
            const type = this.dataset.type;
            sortAsc = (sortCol === col) ? !sortAsc : true;
            sortCol = col;

            document.querySelectorAll('#mainTable th .sort-icon').forEach(i => i.className = 'bi bi-arrow-down-up sort-icon');
            this.querySelector('.sort-icon').className = 'bi bi-arrow-' + (sortAsc ? 'up' : 'down') + ' sort-icon';

            const tbody = document.querySelector('#mainTable tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            rows.sort((a, b) => {
                const va = a.cells[col] ? a.cells[col].textContent.trim() : '';
                const vb = b.cells[col] ? b.cells[col].textContent.trim() : '';
                let cmp = type === 'date' ? parseDate(va) - parseDate(vb) : va.localeCompare(vb, 'fr');
                return sortAsc ? cmp : -cmp;
            });
            rows.forEach(r => tbody.appendChild(r));
        });
    });
})();
</script>{% endblock %}
