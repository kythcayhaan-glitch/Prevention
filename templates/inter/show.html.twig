{% extends 'base.html.twig' %}
{% block title %}Intervention #{{ inter.id }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> Intervention #{{ inter.id }}</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('app_inter_edit', {id: inter.id}) }}" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Modifier</a>
        <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-danger text-white">Détail</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Date</dt><dd class="col-sm-8">{{ inter.date }}</dd>
                    <dt class="col-sm-4">Type</dt><dd class="col-sm-8"><span class="badge bg-info text-dark">{{ inter.type }}</span></dd>
                    <dt class="col-sm-4">Service</dt><dd class="col-sm-8">{{ inter.service }}</dd>
                    <dt class="col-sm-4">Urgence</dt><dd class="col-sm-8">{% if inter.urgence == 'oui' %}<span class="badge bg-danger">Oui</span>{% else %}Non{% endif %}</dd>
                    <dt class="col-sm-4">Description</dt><dd class="col-sm-8">{{ inter.panneAnnonce }}</dd>
                    <dt class="col-sm-4">Intervention</dt><dd class="col-sm-8">{{ inter.interEffect|nl2br }}</dd>
                    <dt class="col-sm-4">Observation</dt><dd class="col-sm-8">{{ inter.observation }}</dd>
                    <dt class="col-sm-4">Par</dt><dd class="col-sm-8">{{ inter.par }}</dd>
                    <dt class="col-sm-4">Saisi par</dt><dd class="col-sm-8">{{ inter.userInter }}</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-secondary text-white">Intervenants & Coûts</div>
            <div class="card-body">
                <dl class="row mb-0">
                    {% if inter.intervenant %}<dt class="col-sm-5">Intervenant 1</dt><dd class="col-sm-7">{{ inter.intervenant }} ({{ inter.tauxIntervenant }} €/h)</dd>{% endif %}
                    {% if inter.intervenant2 %}<dt class="col-sm-5">Intervenant 2</dt><dd class="col-sm-7">{{ inter.intervenant2 }} ({{ inter.tauxIntervenant2 }} €/h)</dd>{% endif %}
                    {% if inter.intervenant3 %}<dt class="col-sm-5">Intervenant 3</dt><dd class="col-sm-7">{{ inter.intervenant3 }} ({{ inter.tauxIntervenant3 }} €/h)</dd>{% endif %}
                    <dt class="col-sm-5">Durée</dt><dd class="col-sm-7">{{ inter.duree }} h</dd>
                    <dt class="col-sm-5">Coût matériel</dt><dd class="col-sm-7">{{ inter.coutMatos }} €</dd>
                    <dt class="col-sm-5">Taux total</dt><dd class="col-sm-7"><strong>{{ inter.tauxTotal }} €</strong></dd>
                </dl>
            </div>
        </div>
        {% if inter.agentVisite %}
        <div class="card mt-3">
            <div class="card-header bg-primary text-white">Visite / RQTH</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Agent</dt><dd class="col-sm-7">{{ inter.agentVisite }}</dd>
                    <dt class="col-sm-5">Service</dt><dd class="col-sm-7">{{ inter.poleServiceVisite }}</dd>
                    <dt class="col-sm-5">Date visite</dt><dd class="col-sm-7">{{ inter.dateVisite }}</dd>
                    <dt class="col-sm-5">RQTH</dt><dd class="col-sm-7">{{ inter.rqthVisite }}</dd>
                    <dt class="col-sm-5">Restrictions</dt><dd class="col-sm-7">{{ inter.restrictionVisite }}</dd>
                </dl>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
