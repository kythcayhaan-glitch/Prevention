{% extends 'base.html.twig' %}
{% block title %}Intervention #{{ inter.id }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> Intervention #{{ inter.id }}</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('app_inter_edit', {id: inter.id}) }}" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Modifier</a>
        <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-danger text-white">Détail</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Date</dt><dd class="col-sm-8">{{ inter.date }}</dd>
<dt class="col-sm-4">Service</dt><dd class="col-sm-8">{{ inter.service }}</dd>
                    <dt class="col-sm-4">Urgence</dt><dd class="col-sm-8">
                        {% if inter.urgence == 'a_traiter' %}<span class="badge bg-danger">A traiter</span>
                        {% elseif inter.urgence == 'en_cours' %}<span class="badge bg-warning text-dark">En cours</span>
                        {% elseif inter.urgence == 'traite' %}<span class="badge bg-success">Traité</span>
                        {% else %}<span class="text-muted">—</span>{% endif %}
                    </dd>
                    <dt class="col-sm-4">Description</dt><dd class="col-sm-8">{{ inter.panneAnnonce }}</dd>
                    <dt class="col-sm-4">Intervention</dt><dd class="col-sm-8">{{ inter.interEffect|nl2br }}</dd>
                    <dt class="col-sm-4">Observation</dt><dd class="col-sm-8">{{ inter.observation }}</dd>
                    <dt class="col-sm-4">Par</dt><dd class="col-sm-8">{{ inter.par }}</dd>
                    <dt class="col-sm-4">Saisi par</dt><dd class="col-sm-8">{{ inter.userInter }}</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}
