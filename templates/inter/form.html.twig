{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> {{ title }}</h2>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
{{ form_start(form) }}
<div class="card mb-3">
    <div class="card-header bg-danger text-white">Informations générales</div>
    <div class="card-body row g-3">
        <div class="col-md-3">{{ form_row(form.date, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.type, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.service, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.urgence, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-12">{{ form_row(form.panneAnnonce, {attr: {class: 'form-control', rows: 3}}) }}</div>
        <div class="col-12">{{ form_row(form.interEffect, {attr: {class: 'form-control', rows: 3}}) }}</div>
        <div class="col-12">{{ form_row(form.observation, {attr: {class: 'form-control', rows: 2}}) }}</div>
    </div>
</div>
<div class="card mb-3">
    <div class="card-header bg-secondary text-white">Intervenants & Coûts</div>
    <div class="card-body row g-3">
        <div class="col-md-3">{{ form_row(form.intervenant, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.tauxIntervenant, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.intervenant2, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.tauxIntervenant2, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.intervenant3, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.tauxIntervenant3, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.duree, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.coutMatos, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.par, {attr: {class: 'form-control'}}) }}</div>
    </div>
</div>
<div class="card mb-3">
    <div class="card-header bg-primary text-white">Visite / RQTH (si applicable)</div>
    <div class="card-body row g-3">
        <div class="col-md-3">{{ form_row(form.agentVisite, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.poleServiceVisite, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.dateVisite, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.rqthVisite, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-4">{{ form_row(form.restrictionVisite, {attr: {class: 'form-control', rows: 2}}) }}</div>
        <div class="col-md-4">{{ form_row(form.recommandationVisite, {attr: {class: 'form-control', rows: 2}}) }}</div>
        <div class="col-md-4">{{ form_row(form.limitationVisite, {attr: {class: 'form-control', rows: 2}}) }}</div>
        <div class="col-md-3">{{ form_row(form.tempsPartielVisite, {attr: {class: 'form-select'}}) }}</div>
    </div>
</div>
<div class="mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>
{{ form_end(form) }}
{% endblock %}
