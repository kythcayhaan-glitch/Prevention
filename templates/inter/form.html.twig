{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
<style>
.sticky-save {
    position: sticky;
    bottom: 0;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(4px);
    padding: .75rem 1rem;
    border-top: 1px solid #dee2e6;
    z-index: 100;
    margin-top: 1rem;
}
.form-control-sm, .form-select-sm {
    background-color: #eaf4fb;
    border-color: #aed6f1;
    color: #154360;
}
.form-control-sm:focus, .form-select-sm:focus {
    background-color: #d6eaf8;
    border-color: #2980b9;
    box-shadow: 0 0 0 .2rem rgba(41,128,185,.2);
}
textarea.form-control-sm {
    background-color: #fdfefe;
    border-color: #aed6f1;
}
textarea.form-control-sm:focus {
    background-color: #fff;
    border-color: #2980b9;
    box-shadow: 0 0 0 .2rem rgba(41,128,185,.2);
}
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> {{ title }}</h2>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
{{ form_start(form) }}
<div class="card mb-3">
    <div class="card-header bg-danger text-white">Informations générales</div>
    <div class="card-body row g-2">
        <div class="col-md-3">
            {{ form_label(form.agentVisite) }}
            <div class="input-group">
                {{ form_widget(form.agentVisite, {attr: {class: 'form-select form-select-sm'}}) }}
                <button type="button" class="btn btn-outline-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalNouvelAgent" title="Créer un nouvel agent"><i class="bi bi-plus-lg"></i></button>
            </div>
            {{ form_errors(form.agentVisite) }}
        </div>
        <div class="w-100"></div>
        <div class="col-auto">{{ form_row(form.date, {attr: {class: 'form-control form-control-sm date-picker', style: 'width:130px'}}) }}</div>
        <div class="w-100"></div>
        <div class="col-md-3">{{ form_row(form.service, {attr: {class: 'form-select form-select-sm'}}) }}</div>
        <div class="col-12">{{ form_row(form.panneAnnonce, {attr: {class: 'form-control form-control-sm', rows: 3}}) }}</div>
        <div class="col-12">
            <label class="form-label fw-semibold">Interventions effectuées
                <button type="button" class="btn btn-sm btn-success ms-2" id="add-action" data-bs-toggle="modal" data-bs-target="#modalNouvelleAction"><i class="bi bi-plus-lg"></i></button>
                <button type="button" class="btn btn-sm btn-outline-secondary ms-1" id="toggle-all-actions" title="Tout ouvrir / fermer"><i class="bi bi-chevron-expand"></i></button>
            </label>
            {% set colors = ['#2980b9','#27ae60','#8e44ad','#e67e22','#16a085','#c0392b','#2471a3','#1e8449'] %}
            <div id="actions-collection" class="accordion">
                {% for action in inter.actions %}
                {% set uid = 'action-' ~ action.id %}
                {% set color = colors[(loop.index0) % colors|length] %}
                <div class="action-item accordion-item" data-action-id="{{ action.id }}" style="border-left: 4px solid {{ color }}">
                    <h2 class="accordion-header d-flex align-items-center" style="background: {{ color }}15">
                        <button class="accordion-button collapsed flex-grow-1 py-2" type="button" data-bs-toggle="collapse" data-bs-target="#{{ uid }}" style="background: transparent; color: {{ color }}; font-weight: 600; box-shadow: none;">
                            <i class="bi bi-calendar2-check me-2"></i>
                            {{ action.date ?: 'Intervention ' ~ loop.index }}
                            {% if action.description %}
                                <span class="ms-2 text-truncate fw-normal" style="max-width:350px; color:#555; font-size:.85rem">— {{ action.description|slice(0,70) }}…</span>
                            {% endif %}
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger ms-2 me-2 remove-action" data-delete-url="{{ path('app_inter_action_delete', {actionId: action.id}) }}"><i class="bi bi-trash"></i></button>
                    </h2>
                    <div id="{{ uid }}" class="accordion-collapse collapse">
                        <div class="accordion-body py-2" style="border-top: 1px solid {{ color }}30">
                            <p class="mb-0" style="white-space: pre-line">{{ action.description }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        <div class="col-12">{{ form_row(form.observation, {attr: {class: 'form-control form-control-sm', rows: 2}}) }}</div>
    </div>
</div>
<div class="sticky-save">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>
{{ form_row(form._token) }}
{{ form_end(form, {render_rest: false}) }}

<div class="modal fade" id="modalNouvelleAction" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i> Nouvelle intervention effectuée</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Date</label>
                    <input type="text" id="modal-action-date" class="form-control date-picker" placeholder="DD/MM/YYYY" style="width:160px">
                </div>
                <div>
                    <label class="form-label fw-semibold">Description</label>
                    <textarea id="modal-action-text" class="form-control" rows="8" placeholder="Décrivez l'intervention effectuée..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-success" id="btn-save-action"><i class="bi bi-check-lg"></i> Ajouter</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNouvelAgent" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nouvel agent</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Nom <span class="text-danger">*</span></label>
                    <input type="text" id="agent-nom" class="form-control text-uppercase" placeholder="NOM">
                </div>
                <div class="mb-2">
                    <label class="form-label">Prénom</label>
                    <input type="text" id="agent-prenom" class="form-control" placeholder="Prénom">
                </div>
                <div id="agent-error" class="text-danger small d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-success" id="btn-save-agent">Créer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}<script>
const createAgentUrl = '{{ path('app_agent_create') }}';

document.getElementById('btn-save-agent').addEventListener('click', function () {
    const nom = document.getElementById('agent-nom').value.trim().toUpperCase();
    const prenom = document.getElementById('agent-prenom').value.trim();
    const errEl = document.getElementById('agent-error');

    if (!nom) { errEl.textContent = 'Le nom est requis.'; errEl.classList.remove('d-none'); return; }
    errEl.classList.add('d-none');

    const fd = new FormData();
    fd.append('nom', nom);
    fd.append('prenom', prenom);

    fetch(createAgentUrl, { method: 'POST', body: fd })
        .then(r => r.json())
        .then(data => {
            if (data.error) { errEl.textContent = data.error; errEl.classList.remove('d-none'); return; }
            const select = document.querySelector('[name$="[agentVisite]"], #inter_agentVisite');
            const opt = new Option(data.label, data.value, true, true);
            select.appendChild(opt);
            select.value = data.value;
            bootstrap.Modal.getInstance(document.getElementById('modalNouvelAgent')).hide();
            document.getElementById('agent-nom').value = '';
            document.getElementById('agent-prenom').value = '';
        });
});

(function () {
    const collection = document.getElementById('actions-collection');
    const actionAddUrl = '{{ action_add_url is defined ? action_add_url : '' }}';
    const colors = ['#2980b9','#27ae60','#8e44ad','#e67e22','#16a085','#c0392b','#2471a3','#1e8449'];

    function colorFor(index) { return colors[index % colors.length]; }

    function attachDelete(btn) {
        btn.addEventListener('click', function () {
            if (!confirm('Supprimer cette intervention effectuée ?')) return;
            const item = this.closest('.action-item');
            const url = this.dataset.deleteUrl;
            if (!url) { item.remove(); return; }
            fetch(url, { method: 'POST' }).then(() => item.remove());
        });
    }

    collection.querySelectorAll('.remove-action').forEach(attachDelete);

    function addItemToDOM(data) {
        const idx = collection.querySelectorAll('.action-item').length;
        const color = colorFor(idx);
        const uid = 'action-' + data.id;
        const div = document.createElement('div');
        div.className = 'action-item accordion-item';
        div.dataset.actionId = data.id;
        div.style.cssText = `border-left: 4px solid ${color}`;
        div.innerHTML = `
            <h2 class="accordion-header d-flex align-items-center" style="background:${color}15">
                <button class="accordion-button flex-grow-1 py-2" type="button" data-bs-toggle="collapse" data-bs-target="#${uid}"
                    style="background:transparent;color:${color};font-weight:600;box-shadow:none;">
                    <i class="bi bi-calendar2-check me-2"></i>
                    ${data.date || 'Intervention'}
                    <span class="ms-2 text-truncate fw-normal" style="max-width:350px;color:#555;font-size:.85rem">
                        — ${data.description.substring(0, 70)}…
                    </span>
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger ms-2 me-2 remove-action" data-delete-url="${data.deleteUrl}"><i class="bi bi-trash"></i></button>
            </h2>
            <div id="${uid}" class="accordion-collapse collapse show" style="border-top:1px solid ${color}30">
                <div class="accordion-body py-2"><p class="mb-0" style="white-space:pre-line">${data.description}</p></div>
            </div>`;
        collection.appendChild(div);
        attachDelete(div.querySelector('.remove-action'));
    }

    document.getElementById('btn-save-action').addEventListener('click', function () {
        const text = document.getElementById('modal-action-text').value.trim();
        const date = document.getElementById('modal-action-date').value.trim();
        if (!text || !actionAddUrl) return;
        const fd = new FormData();
        fd.append('description', text);
        fd.append('date', date);
        fetch(actionAddUrl, { method: 'POST', body: fd })
            .then(r => r.json())
            .then(data => {
                if (data.error) return;
                addItemToDOM(data);
                document.getElementById('modal-action-text').value = '';
                document.getElementById('modal-action-date').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalNouvelleAction')).hide();
            });
    });

    document.getElementById('modalNouvelleAction').addEventListener('shown.bs.modal', function () {
        document.getElementById('modal-action-text').value = '';
        document.getElementById('modal-action-date').value = '';
        if (typeof initDatePickers === 'function') initDatePickers(this);
    });

    let allOpen = false;
    document.getElementById('toggle-all-actions').addEventListener('click', function () {
        const panels = collection.querySelectorAll('.accordion-collapse');
        allOpen = !allOpen;
        panels.forEach(p => {
            bootstrap.Collapse.getOrCreateInstance(p, {toggle: false})[allOpen ? 'show' : 'hide']();
        });
        this.querySelector('i').className = allOpen ? 'bi bi-chevron-contract' : 'bi bi-chevron-expand';
    });
})();
</script>{% endblock %}
