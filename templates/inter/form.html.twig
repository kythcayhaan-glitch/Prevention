{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> {{ title }}</h2>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
{{ form_start(form) }}
<div class="card mb-3">
    <div class="card-header bg-danger text-white">Informations générales</div>
    <div class="card-body row g-3">
        <div class="col-md-3">{{ form_row(form.date, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.type, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.service, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.urgence, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.agentVisite, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-12">{{ form_row(form.panneAnnonce, {attr: {class: 'form-control', rows: 3}}) }}</div>
        <div class="col-12">
            <div class="accordion" id="accordionInterEffect">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseInterEffect" aria-expanded="false">
                            Intervention effectuée
                        </button>
                    </h2>
                    <div id="collapseInterEffect" class="accordion-collapse collapse" data-bs-parent="#accordionInterEffect">
                        <div class="accordion-body p-2">
                            {{ form_row(form.interEffect, {label: false, attr: {class: 'form-control', rows: 5}}) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12">{{ form_row(form.observation, {attr: {class: 'form-control', rows: 2}}) }}</div>
    </div>
</div>
<div class="mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>
{{ form_end(form) }}
{% endblock %}
