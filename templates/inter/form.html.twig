{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tools"></i> {{ title }}</h2>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
{{ form_start(form) }}
<div class="card mb-3">
    <div class="card-header bg-danger text-white">Informations générales</div>
    <div class="card-body row g-3">
        <div class="col-md-3">{{ form_row(form.date, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.type, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.service, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">{{ form_row(form.urgence, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-3">
            {{ form_label(form.agentVisite) }}
            <div class="input-group">
                {{ form_widget(form.agentVisite, {attr: {class: 'form-select'}}) }}
                <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#modalNouvelAgent" title="Créer un nouvel agent"><i class="bi bi-plus-lg"></i></button>
            </div>
            {{ form_errors(form.agentVisite) }}
        </div>
        <div class="col-12">{{ form_row(form.panneAnnonce, {attr: {class: 'form-control', rows: 3}}) }}</div>
        <div class="col-12">
            <label class="form-label fw-semibold">Interventions effectuées
                <button type="button" class="btn btn-sm btn-success ms-2" id="add-action"><i class="bi bi-plus-lg"></i></button>
            </label>
            <div id="actions-collection" class="accordion" data-prototype="{{ form_widget(form.actions.vars.prototype)|e('html_attr') }}">
                {% for action in form.actions %}
                {% set uid = 'action-' ~ loop.index %}
                <div class="action-item accordion-item">
                    <h2 class="accordion-header d-flex align-items-center">
                        <button class="accordion-button collapsed flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#{{ uid }}">
                            {{ action.vars.data.date ?: 'Intervention ' ~ loop.index }}
                            {% if action.vars.data.description %}
                                <span class="text-muted small ms-2 text-truncate" style="max-width:300px">— {{ action.vars.data.description|slice(0,60) }}…</span>
                            {% endif %}
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger ms-2 me-2 remove-action"><i class="bi bi-trash"></i></button>
                    </h2>
                    <div id="{{ uid }}" class="accordion-collapse collapse">
                        <div class="accordion-body">
                            <div class="row g-2">
                                <div class="col-md-2">{{ form_row(action.date, {attr: {class: 'form-control date-picker'}}) }}</div>
                                <div class="col-md-10">{{ form_row(action.description, {attr: {class: 'form-control', rows: 3}}) }}</div>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        <div class="col-12">{{ form_row(form.observation, {attr: {class: 'form-control', rows: 2}}) }}</div>
    </div>
</div>
<div class="mt-3">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('app_inter_index') }}" class="btn btn-outline-secondary ms-2">Annuler</a>
</div>
{{ form_end(form) }}

<div class="modal fade" id="modalNouvelAgent" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nouvel agent</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label class="form-label">Nom <span class="text-danger">*</span></label>
                    <input type="text" id="agent-nom" class="form-control text-uppercase" placeholder="NOM">
                </div>
                <div class="mb-2">
                    <label class="form-label">Prénom</label>
                    <input type="text" id="agent-prenom" class="form-control" placeholder="Prénom">
                </div>
                <div id="agent-error" class="text-danger small d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-success" id="btn-save-agent">Créer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}<script>
const createAgentUrl = '{{ path('app_agent_create') }}';

document.getElementById('btn-save-agent').addEventListener('click', function () {
    const nom = document.getElementById('agent-nom').value.trim().toUpperCase();
    const prenom = document.getElementById('agent-prenom').value.trim();
    const errEl = document.getElementById('agent-error');

    if (!nom) { errEl.textContent = 'Le nom est requis.'; errEl.classList.remove('d-none'); return; }
    errEl.classList.add('d-none');

    const fd = new FormData();
    fd.append('nom', nom);
    fd.append('prenom', prenom);

    fetch(createAgentUrl, { method: 'POST', body: fd })
        .then(r => r.json())
        .then(data => {
            if (data.error) { errEl.textContent = data.error; errEl.classList.remove('d-none'); return; }
            const select = document.querySelector('[name$="[agentVisite]"], #inter_agentVisite');
            const opt = new Option(data.label, data.value, true, true);
            select.appendChild(opt);
            select.value = data.value;
            bootstrap.Modal.getInstance(document.getElementById('modalNouvelAgent')).hide();
            document.getElementById('agent-nom').value = '';
            document.getElementById('agent-prenom').value = '';
        });
});

(function () {
    const collection = document.getElementById('actions-collection');
    let index = collection.querySelectorAll('.action-item').length;

    function addItem() {
        const uid = 'action-new-' + index;
        const proto = collection.dataset.prototype.replace(/__name__/g, index++);
        const div = document.createElement('div');
        div.className = 'action-item accordion-item';
        div.innerHTML = `
            <h2 class="accordion-header d-flex align-items-center">
                <button class="accordion-button flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#${uid}">
                    Nouvelle intervention
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger ms-2 me-2 remove-action"><i class="bi bi-trash"></i></button>
            </h2>
            <div id="${uid}" class="accordion-collapse collapse show">
                <div class="accordion-body"><div class="row g-2">${proto}</div></div>
            </div>`;
        collection.appendChild(div);
        if (typeof initDatePickers === 'function') initDatePickers(div);
        div.querySelector('.remove-action').addEventListener('click', () => div.remove());
        initAutoResize(div);
    }

    document.getElementById('add-action').addEventListener('click', addItem);

    collection.querySelectorAll('.remove-action').forEach(btn => {
        btn.addEventListener('click', () => btn.closest('.action-item').remove());
    });

    function autoResize(ta) {
        const lines = (ta.value.match(/\n/g) || []).length + 1;
        ta.rows = Math.max(2, lines);
    }

    function initAutoResize(root) {
        root.querySelectorAll('textarea').forEach(ta => {
            autoResize(ta);
            ta.addEventListener('input', () => autoResize(ta));
        });
    }

    initAutoResize(collection);

})();
</script>{% endblock %}
