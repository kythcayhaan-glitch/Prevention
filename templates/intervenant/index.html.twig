{% extends 'base.html.twig' %}
{% block title %}Intervenants{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Intervenants</h2>
    <a href="{{ path('app_intervenant_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ajouter</a>
</div>
<div class="card" style="max-width:700px">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead><tr><th>#</th><th>Nom</th><th>Service</th><th>Taux (€/h)</th><th>Actions</th></tr></thead>
                <tbody>
                {% for item in intervenants %}
                <tr data-href="{{ path('app_intervenant_edit', {id: item.id}) }}">
                    <td class="text-muted">{{ item.id }}</td>
                    <td><strong>{{ item.nom }}</strong></td>
                    <td>{{ item.service }}</td>
                    <td>{{ item.tauxInter ? item.tauxInter ~ ' €' : '—' }}</td>
                    <td class="text-nowrap" onclick="event.stopPropagation()">
                        <a href="{{ path('app_intervenant_edit', {id: item.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="{{ path('app_intervenant_delete', {id: item.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer la suppression ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="5" class="text-center text-muted py-5"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Aucun intervenant.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
