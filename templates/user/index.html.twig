{% extends 'base.html.twig' %}
{% block title %}Utilisateurs{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-gear"></i> Utilisateurs</h2>
    <a href="{{ path('app_user_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ajouter</a>
</div>
<div class="card"><div class="table-responsive"><table class="table table-hover mb-0">
<thead><tr><th>#</th><th>Login</th><th>Nom</th><th>Service</th><th>Profil</th><th>Actions</th></tr></thead>
<tbody>
{% for item in users %}
<tr><td>{{ item.id }}</td><td>{{ item.login }}</td><td>{{ item.nom }}</td><td>{{ item.service }}</td>
    <td><span class="badge bg-{{ item.idProfil == 2 ? 'danger' : (item.idProfil == 1 ? 'warning text-dark' : 'secondary') }}">
        {{ item.idProfil == 2 ? 'Super Admin' : (item.idProfil == 1 ? 'Admin' : 'Agent') }}
    </span></td>
    <td>
        <a href="{{ path('app_user_edit', {id: item.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
        <form method="post" action="{{ path('app_user_delete', {id: item.id}) }}" style="display:inline" onsubmit="return confirm('Confirmer ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
        </form>
    </td>
</tr>
{% else %}<tr><td colspan="6" class="text-center text-muted py-4">Aucun utilisateur.</td></tr>{% endfor %}
</tbody></table></div></div>
{% endblock %}
